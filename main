-- Load the Rayfield Library
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Create the main window with Bloom theme
local Window = Rayfield:CreateWindow({
    Name = "Koontang is fat",
    LoadingTitle = "Loading Koontang is fat...",
    LoadingSubtitle = "With Working Hooks",
    Theme = "Bloom",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "KoontangIsFatConfig",
        FileName = "Settings"
    },
    Discord = {
        Enabled = false,
        Invite = "noinvitelink",
        RememberJoins = true
    },
    KeySystem = false
})

-- Create tabs
local Tab = Window:CreateTab("Auto Rally", 4483362458)
local GrabberTab = Window:CreateTab("Key Grabber", 4483362458)

-- Variables
local isAutoRallyEnabled = false
local REQEvent = game:GetService("ReplicatedStorage").Remote.REQ
local playerKey = ""
local capturedKey = ""
local hookInstalled = false

-- ========== WORKING HOOK METHOD (WON'T BREAK MENU) ==========
local function InstallKeyGrabberHook()
    if hookInstalled then
        print("⚠️ Hook already installed!")
        return
    end
    
    print("🔄 Installing key grabber hook...")
    
    -- Save the original
    local oldNamecall
    
    -- Use pcall to prevent crashes
    local success = pcall(function()
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            -- ALWAYS call original first to prevent breaking things
            local results = {oldNamecall(self, ...)}
            
            -- Only do our stuff after the original call
            local success2, err = pcall(function()
                local method = getnamecallmethod()
                
                -- Check if this is our target
                if self == REQEvent and method == "InvokeServer" then
                    local args = {...}
                    
                    -- Log what we found
                    print("🔑 REQ Intercepted!")
                    for i = 1, #args do
                        print("  Arg" .. i .. ": " .. tostring(args[i]))
                        if type(args[i]) == "string" and #args[i] > 10 then
                            capturedKey = args[i]
                            print("✅ KEY CAPTURED: " .. capturedKey)
                            
                            -- Update UI safely
                            pcall(function()
                                KeyInput:Set(capturedKey)
                                StatusLabel:Set("Key captured: " .. string.sub(capturedKey, 1, 15) .. "...")
                            end)
                        end
                    end
                end
            end)
            
            if not success2 then
                warn("Hook error (ignored): " .. tostring(err))
            end
            
            return unpack(results)
        end)
    end)
    
    if success then
        hookInstalled = true
        print("✅ Hook installed successfully!")
        print("📋 Now use the rally feature - key will be captured automatically")
    else
        print("❌ Failed to install hook")
    end
end

-- Function to remove hook (if needed)
local function RemoveHook()
    if hookInstalled then
        -- Can't really remove a hook, but we can set a flag
        hookInstalled = false
        print("🔄 Hook disabled (flag set)")
    end
end

-- UI for Key Grabber tab
local InstallHookButton = GrabberTab:CreateButton({
    Name = "Install Key Grabber Hook",
    Callback = function()
        InstallKeyGrabberHook()
    end
})

local StatusLabel = GrabberTab:CreateLabel("Status: Hook not installed")

local ClearButton = GrabberTab:CreateButton({
    Name = "Clear Console",
    Callback = function()
        for i = 1, 30 do print("") end
    end
})

local Instructions = GrabberTab:CreateLabel("INSTRUCTIONS:")
local Step1 = GrabberTab:CreateLabel("1. Click 'Install Key Grabber Hook'")
local Step2 = GrabberTab:CreateLabel("2. Use the rally feature in-game")
local Step3 = GrabberTab:CreateLabel("3. Key will appear below when captured")
local Step4 = GrabberTab:CreateLabel("4. Switch to Auto Rally tab to use it")

-- ========== AUTO RALLY SECTION ==========
local function ExecuteRally()
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ No key available! Use Key Grabber first.")
        return
    end
    
    print("🚀 Executing rally with key: " .. keyToUse)
    
    local success, err = pcall(function()
        REQEvent:InvokeServer(
            keyToUse,
            "PDS",
            "handleRallied",
            {2, 2, 2, 2, 2, 2, 2, 2, 2}
        )
    end)
    
    if success then
        print("✅ Rally executed at: " .. os.date("%H:%M:%S"))
    else
        print("❌ Rally failed: " .. tostring(err))
    end
end

local function StartAutoRally(interval)
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ No key available! Use Key Grabber first.")
        AutoRallyToggle:Set(false)
        return
    end
    
    isAutoRallyEnabled = true
    print("▶️ Auto Rally started - Interval: " .. interval .. "s")
    
    task.spawn(function()
        while isAutoRallyEnabled do
            ExecuteRally()
            task.wait(interval)
        end
    end)
end

local function StopAutoRally()
    isAutoRallyEnabled = false
    print("⏹️ Auto Rally stopped")
end

-- Auto Rally UI
local KeyInput = Tab:CreateInput({
    Name = "Your Key (auto-filled when captured)",
    PlaceholderText = "Key will appear here automatically",
    RemoveTextAfterFocusLost = false,
    Flag = "PlayerKey",
    Callback = function(Text)
        playerKey = Text
    end
})

local IntervalSlider = Tab:CreateSlider({
    Name = "Interval (seconds)",
    Range = {0.1, 10},
    Increment = 0.1,
    CurrentValue = 2,
    Flag = "IntervalSetting"
})

local AutoRallyToggle = Tab:CreateToggle({
    Name = "Auto Rally",
    CurrentValue = false,
    Flag = "AutoRallyToggle",
    Callback = function(Value)
        if Value then
            StartAutoRally(IntervalSlider.CurrentValue)
        else
            StopAutoRally()
        end
    end
})

local ManualButton = Tab:CreateButton({
    Name = "Execute Once",
    Callback = function()
        ExecuteRally()
    end
})

local ShowKeyButton = Tab:CreateButton({
    Name = "Show Current Key",
    Callback = function()
        if capturedKey ~= "" then
            print("🔑 Captured key: " .. capturedKey)
        elseif playerKey ~= "" then
            print("🔑 Manual key: " .. playerKey)
        else
            print("⚠️ No key available")
        end
    end
})

-- Emergency reset
local ResetButton = Tab:CreateButton({
    Name = "Emergency Reset",
    Callback = function()
        isAutoRallyEnabled = false
        AutoRallyToggle:Set(false)
        print("✅ Reset complete")
    end
})

-- Load configuration
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
playerKey = KeyInput.CurrentValue or ""
if playerKey ~= "" then
    print("💾 Loaded saved key")
end

-- Update status periodically
task.spawn(function()
    while true do
        if hookInstalled then
            StatusLabel:Set("Status: Hook Active ✅")
        else
            StatusLabel:Set("Status: Hook Inactive ❌")
        end
        task.wait(1)
    end
end)
