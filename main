-- ========== OBFUSCATED AUTO BATTLE SCRIPT ==========
-- Load the obfuscated auto battle code
local obfuscatedCode = [[
-- This code was generated by Cobalt
-- https://github.com/notpoiu/cobalt

_G.Move = "move 2"

-- This file was generated using Luraph Obfuscator v11.3 by memcorrupt.

local lIlllilI1Il1Il11illi1 = assert local iIi1Iili11ii1iIll1l = select local iiiiIliIll1liiIiliI = tonumber local lIlllIi1IiIllliI1IIIl = unpack local Ii1i11llli111I11l1I = pcall local lIiI1II1iIiii1iIl11 = setfenv local i1iilIIiil1I1Ii1il1 = setmetatable local l1iI1llIilI1llI1Il1 = type local Ii1III1lliIIiIlIIli = getfenv local I1illilllI1liIIi11l = tostring local lIIi111liIililI1lii = error local lIl1Il1iIil1I1I1iIlI1 = string.sub local lIli1II1Ii11IIII1il1l = string.byte local ii1IiliIl1IlI1l1ii1 = string.char local lIlliiil1I11II111l1Ii = string.rep local iIl1ilill1i1liIi1li = string.gsub local lIlIIiI1lIlIil1I1IllI = string.match local I1iIliI1I1iIlIliili = 1
]]

-- Execute the obfuscated code
local success, err = pcall(function()
    loadstring(obfuscatedCode)()
end)

if not success then
    warn("Failed to load auto battle script: " .. tostring(err))
end

-- ========== MAIN HUNTING LOOP ==========
task.spawn(function()
    while task.wait() do
        pcall(function()
            if TeleportToggle and TeleportToggle.CurrentValue and not isInBattle() then
                local eggs = getEggs()
                for _, egg in ipairs(eggs) do
                    if not TeleportToggle.CurrentValue or isInBattle() then 
                        break 
                    end
                    if egg and egg.Parent then
                        humanoid.RootPart.CFrame = CFrame.new(egg.Position)
                        task.wait(teleportRate)
                    end
                end
            end
        end)
    end
end)

-- Initialize
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
if KeyInput and KeyInput.CurrentValue then
    playerKey = KeyInput.CurrentValue
    if playerKey ~= "" then
        print("💾 Loaded saved key: " .. playerKey)
    end
end

-- Welcome Notification
task.wait(1)
Rayfield:Notify({
   Title = "OWNER SYSTEM ONLINE",
   Content = "Premium controls activated\nAuto Rally + Auto Battle",
   Duration = 6,
   Image = "shield-check"
})
