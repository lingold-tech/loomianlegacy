-- Load the Rayfield Library
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Create the main window with Bloom theme
local Window = Rayfield:CreateWindow({
    Name = "Koontang is fat",
    LoadingTitle = "Loading Koontang is fat...",
    LoadingSubtitle = "ID Grabber Edition",
    Theme = "Bloom",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "KoontangIsFatConfig",
        FileName = "Settings"
    },
    Discord = {
        Enabled = false,
        Invite = "noinvitelink",
        RememberJoins = true
    },
    KeySystem = false
})

-- Create tabs
local Tab = Window:CreateTab("Auto Rally", 4483362458)
local IDGrabberTab = Window:CreateTab("ID Grabber", 4483362458)

-- Variables
local isAutoRallyEnabled = false
local loopConnection = nil
local Event = game:GetService("ReplicatedStorage").Remote.REQ
local playerKey = ""

-- ========== SIMPLE ID GRABBER ==========
local function SetupSimpleIDGrabber()
    -- Clear console
    for i = 1, 30 do print("") end
    print("=== SIMPLE ID GRABBER ACTIVATED ===")
    print("1. Go to the 'Auto Rally' tab")
    print("2. Click 'Execute Once' manually")
    print("3. Watch for the output below:")
    print("====================================")
    
    -- Simple hook for REQ (InvokeServer)
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        -- Check if this is the REQ remote being called
        if self == Event and method == "InvokeServer" then
            print("🔥 INTERCEPTED INVOKESERVER! 🔥")
            print("Arguments:")
            for i, v in ipairs(args) do
                print("  Arg " .. i .. ":", v)
                -- If it looks like a key/ID (long string), save it
                if type(v) == "string" and #v > 10 then
                    playerKey = v
                    print("✅ POTENTIAL KEY FOUND: " .. v)
                    -- Try to auto-fill
                    KeyInput:Set(v)
                end
            end
            print("========================")
        end
        
        -- Always call original
        return oldNamecall(self, ...)
    end)
    
    -- Also try to hook the EVT remote
    local EVT = game:GetService("ReplicatedStorage").Remote:FindFirstChild("EVT")
    if EVT then
        local oldFireServer
        oldFireServer = hookfunction(EVT.FireServer, function(self, ...)
            local args = {...}
            
            print("🔥 INTERCEPTED EVT:FIRESERVER! 🔥")
            print("Arguments:")
            for i, v in ipairs(args) do
                print("  Arg " .. i .. ":", v)
                if type(v) == "string" and #v > 10 then
                    playerKey = v
                    print("✅ POTENTIAL KEY FOUND: " .. v)
                    KeyInput:Set(v)
                end
            end
            print("========================")
            
            return oldFireServer(self, ...)
        end)
    end
end

-- Even simpler: Just log ALL remote events
local function LogAllRemotes()
    print("🔍 Logging ALL remote calls...")
    
    -- Hook all remote events
    local mt = getrawmetatable(game)
    local old = mt.__namecall
    setreadonly(mt, false)
    
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        -- Check if it's a remote call
        if (method == "FireServer" or method == "InvokeServer") and self:IsA("RemoteEvent") or self:IsA("RemoteFunction") then
            print("📡 Remote:", self.Name)
            print("   Method:", method)
            print("   Args:", unpack(args))
            print("---")
            
            -- Look for long strings (possible keys)
            for i, v in ipairs(args) do
                if type(v) == "string" and #v > 15 then
                    print("🎯 POSSIBLE KEY FOUND: " .. v)
                    playerKey = v
                    KeyInput:Set(v)
                end
            end
        end
        
        return old(self, ...)
    end)
    
    setreadonly(mt, true)
    print("✅ Remote logger activated! Check console for all remote calls.")
end

-- ID Grabber UI
local ActivateSimple = IDGrabberTab:CreateButton({
    Name = "Activate Simple ID Grabber",
    Callback = function()
        SetupSimpleIDGrabber()
    end
})

local ActivateLogger = IDGrabberTab:CreateButton({
    Name = "Activate Remote Logger (Recommended)",
    Callback = function()
        LogAllRemotes()
    end
})

local ClearConsole = IDGrabberTab:CreateButton({
    Name = "Clear Console",
    Callback = function()
        for i = 1, 50 do
            print(" ")
        end
        print("=== CONSOLE CLEARED ===")
    end
})

local Instructions = IDGrabberTab:CreateLabel("Instructions:")
local Step1 = IDGrabberTab:CreateLabel("1. Click 'Activate Remote Logger'")
local Step2 = IDGrabberTab:CreateLabel("2. Open console (F9)")
local Step3 = IDGrabberTab:CreateLabel("3. Go to Auto Rally tab")
local Step4 = IDGrabberTab:CreateLabel("4. Click 'Execute Once'")
local Step5 = IDGrabberTab:CreateLabel("5. Look for '🎯 POSSIBLE KEY FOUND'")

-- ========== AUTO RALLY SECTION ==========
local function ExecuteRally()
    if playerKey == "" then
        print("⚠️ Please enter your key first!")
        return
    end
    
    local success, err = pcall(function()
        Event:InvokeServer(
            playerKey,
            "PDS",
            "handleRallied",
            {
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2
            }
        )
    end)
    
    if success then
        print("✅ Rally executed at: " .. os.date("%H:%M:%S"))
    else
        print("❌ Rally failed: " .. tostring(err))
    end
end

local function StartAutoRally(interval)
    if playerKey == "" then
        print("⚠️ Cannot start Auto Rally - Please enter your key first!")
        AutoRallyToggle:Set(false)
        return
    end
    
    if loopConnection then
        loopConnection:Disconnect()
    end
    
    loopConnection = game:GetService("RunService").Heartbeat:Connect(function()
        ExecuteRally()
        task.wait(interval)
    end)
end

local function StopAutoRally()
    if loopConnection then
        loopConnection:Disconnect()
        loopConnection = nil
    end
    isAutoRallyEnabled = false
    print("⏹️ Auto Rally stopped")
end

-- Auto Rally UI
local KeyInput = Tab:CreateInput({
    Name = "Enter Your Key",
    PlaceholderText = "Key will appear here when grabbed",
    RemoveTextAfterFocusLost = false,
    Flag = "PlayerKey",
    Callback = function(Text)
        playerKey = Text
        print("🔑 Key saved: " .. Text)
    end
})

local IntervalSlider = Tab:CreateSlider({
    Name = "Interval (seconds)",
    Range = {0.1, 10},
    Increment = 0.1,
    CurrentValue = 2,
    Flag = "IntervalSetting",
    Callback = function(Value)
        if isAutoRallyEnabled then
            StartAutoRally(Value)
        end
    end
})

local AutoRallyToggle = Tab:CreateToggle({
    Name = "Auto Rally",
    CurrentValue = false,
    Flag = "AutoRallyToggle",
    Callback = function(Value)
        isAutoRallyEnabled = Value
        if Value then
            local interval = IntervalSlider.CurrentValue
            StartAutoRally(interval)
            print("▶️ Auto Rally started - Interval: " .. interval .. " seconds")
        else
            StopAutoRally()
        end
    end
})

local ManualButton = Tab:CreateButton({
    Name = "Execute Once",
    Callback = function()
        ExecuteRally()
    end
})

-- Load configuration
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
playerKey = KeyInput.CurrentValue or ""
if AutoRallyToggle.CurrentValue and playerKey ~= "" then
    isAutoRallyEnabled = true
    StartAutoRally(IntervalSlider.CurrentValue)
end
