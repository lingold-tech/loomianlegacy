local Main = nil
local WildBattleToggle = false
local FastForwardToggle = false

-- Rally Variables
local isRallyRunning = false
local isMonitoringRanch = false
local monitoringConnection = nil
local REQEvent = game:GetService("ReplicatedStorage"):FindFirstChild("Remote") and game:GetService("ReplicatedStorage").Remote:FindFirstChild("REQ")
local playerKey = ""

-- Total Rallied Counter
local totalRallied = 0
local currentRallied = 0
local ralliedLabel = nil

-- Target Rallied Setting
local targetRallied = 9
local targetMode = "Equals" -- "Equals" or "GreaterThan"

-- Rally Data Storage
local rallyData = {}
local rallyDataLabels = {}
local rallyDataScroll = nil

-- Safety check for REQ event
if not REQEvent then
    warn("REQ Remote not found! Auto Rally may not work.")
end

-- Clean up existing sounds
for _, sound in pairs(workspace:GetDescendants()) do
    if sound:IsA("Sound") then sound:Destroy() end
end

-- Music System
local function playMusic()
    if musicSound then musicSound:Stop() end
    musicSound = Instance.new("Sound")
    musicSound.Parent = workspace
    musicSound.SoundId = "rbxassetid://"..musicId
    musicSound.Looped = true
    musicSound.Volume = 0.5
    musicSound:Play()
end

-- Anti-lag system
local function optimizeGame()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        game.Lighting.GlobalShadows = false
        for _,v in pairs(game.Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                v.Enabled = false
            elseif v:IsA("BasePart") and v.Material == Enum.Material.Grass then
                v.Material = Enum.Material.SmoothPlastic
            end
        end
    end)
end

local function deactivateLag()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        game.Lighting.GlobalShadows = true
        for _,v in pairs(game.Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                v.Enabled = true
            end
        end
    end)
end

-- Battle Detection
local function isInBattle()
    return PlayerGui:FindFirstChild("BattleGui", true) ~= nil
end

-- Egg Detection System
local function getEggs()
    local eggs = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "Egg" and obj.Position.Y <= yLimit then
            table.insert(eggs, obj)
        end
    end
    return eggs
end

-- Function to recursively format any data type for display
local function formatDataForDisplay(data, indent, lines)
    indent = indent or 0
    lines = lines or {}
    local indentStr = string.rep("  ", indent)
    
    if data == nil then
        table.insert(lines, indentStr .. "nil")
    elseif type(data) == "table" then
        table.insert(lines, indentStr .. "{")
        for key, value in pairs(data) do
            local keyStr = tostring(key)
            -- Start the line with the key
            local lineStart = indentStr .. "  [" .. keyStr .. "] = "
            -- Format the value
            local valueLines = {}
            formatDataForDisplay(value, indent + 1, valueLines)
            -- Add the first line with the key
            if #valueLines > 0 then
                table.insert(lines, lineStart .. valueLines[1]:sub(indentStr:len() + 3))
                -- Add remaining lines without the key
                for i = 2, #valueLines do
                    table.insert(lines, valueLines[i])
                end
            end
        end
        table.insert(lines, indentStr .. "}")
    elseif type(data) == "string" then
        table.insert(lines, indentStr .. '"' .. data .. '"')
    elseif type(data) == "number" then
        table.insert(lines, indentStr .. data)
    elseif type(data) == "boolean" then
        table.insert(lines, indentStr .. tostring(data))
    else
        table.insert(lines, indentStr .. tostring(data))
    end
    
    return lines
end

-- Function to update rally data display with ALL data
local function updateRallyDataDisplay()
    if not rallyDataLabels then return end
    
    -- Clear ALL existing labels
    for i, label in ipairs(rallyDataLabels) do
        if label then
            label:Set("")
        end
    end
    
    if rallyData and next(rallyData) then
        -- Format ALL data recursively
        local formattedLines = formatDataForDisplay(rallyData)
        
        -- Create or update labels for EVERY line
        for i, line in ipairs(formattedLines) do
            if rallyDataLabels[i] then
                -- Update existing label
                rallyDataLabels[i]:Set(line)
            else
                -- Create new label
                rallyDataLabels[i] = RallyDataTab:CreateLabel(line)
            end
        end
        
        -- Count total items for stats
        local totalItems = 0
        local totalKeys = 0
        local function countItems(tbl)
            if type(tbl) == "table" then
                for k, v in pairs(tbl) do
                    totalKeys = totalKeys + 1
                    if type(v) == "table" then
                        countItems(v)
                    else
                        totalItems = totalItems + 1
                    end
                end
            end
        end
        countItems(rallyData)
        
        -- Update stats label
        if rallyDataStats then
            rallyDataStats:Set("📊 Total lines: " .. #formattedLines .. " | Keys: " .. totalKeys .. " | Values: " .. totalItems .. " | Updated: " .. os.date("%H:%M:%S"))
        end
        
        print("✅ Displayed " .. #formattedLines .. " lines of rally data")
    else
        -- Show no data message
        if rallyDataLabels[1] then
            rallyDataLabels[1]:Set("No rally data available. Click 'Fetch Rally Data' to load.")
        end
        if rallyDataStats then
            rallyDataStats:Set("📊 No data loaded")
        end
    end
end

-- ========== STRICT 3-STEP CLAIM SEQUENCE ==========
local function ExecuteStrictClaimSequence()
    if not REQEvent then
        print("❌ REQ Remote not found!")
        return false
    end
    
    if playerKey == "" then
        print("⚠️ Please enter your key first!")
        return false
    end
    
    print("🎯 Executing STRICT 3-step claim sequence...")
    
    local success, err = pcall(function()
        -- STEP 1: ranchStatus (MUST be first)
        print("  Step 1/3: ranchStatus")
        local ranchResult = REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "ranchStatus"
        )
        
        -- Update current rallied from ranchStatus
        if ranchResult and type(ranchResult) == "table" and ranchResult.rallied then
            currentRallied = ranchResult.rallied
            print("  Current rallied: " .. currentRallied)
        end
        
        -- STEP 2: getRallied (MUST be second)
        print("  Step 2/3: getRallied")
        local getRalliedResult = REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "getRallied"
        )
        
        -- Store rally data
        if getRalliedResult then
            rallyData = getRalliedResult
            updateRallyDataDisplay()
        end
        
        -- STEP 3: handleRallied (MUST be third)
        print("  Step 3/3: handleRallied")
        REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "handleRallied",
            {
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2
            }
        )
        
        -- Increment counter after successful claim
        totalRallied = totalRallied + 1
        
        -- Single notification for successful claim
        Rayfield:Notify({
            Title = "✅ RALLY CLAIMED",
            Content = "Successfully claimed at " .. currentRallied,
            Duration = 2,
            Image = "check-circle"
        })
        
        print("✅ Strict claim sequence completed at: " .. os.date("%H:%M:%S"))
        return true
    end)
    
    if not success then
        print("❌ Claim sequence failed: " .. tostring(err))
        Rayfield:Notify({
            Title = "❌ CLAIM FAILED",
            Content = "Error in sequence: " .. tostring(err):sub(1, 50),
            Duration = 3,
            Image = "alert-triangle"
        })
        return false
    end
    
    return true
end

-- Function to check ranchStatus continuously (NO CLAIMING HERE)
local function StartRanchMonitoring()
    if isMonitoringRanch then
        print("⚠️ Ranch monitoring already active!")
        return
    end
    
    if playerKey == "" then
        print("⚠️ Please enter your key first!")
        return
    end
    
    isMonitoringRanch = true
    print("🔄 Started continuous ranch monitoring...")
    print("📊 Will check every " .. MonitorSpeedSlider.CurrentValue .. " seconds")
    
    -- Run monitoring in a separate thread
    task.spawn(function()
        while isMonitoringRanch do
            pcall(function()
                -- ONLY call ranchStatus for monitoring
                local ranchResult = REQEvent:InvokeServer(
                    playerKey,
                    "PDS",
                    "ranchStatus"
                )
                
                -- Extract rallied number
                if ranchResult and type(ranchResult) == "table" and ranchResult.rallied then
                    currentRallied = ranchResult.rallied
                elseif ranchResult then
                    for _, value in pairs(ranchResult) do
                        if type(value) == "number" then
                            currentRallied = value
                            break
                        end
                    end
                end
                
                -- Update display (NO NOTIFICATION)
                if ralliedLabel then
                    local targetDisplay = targetMode == "Equals" and "==" or "≥"
                    ralliedLabel:Set("Total: " .. totalRallied .. " | Current: " .. currentRallied .. " | Target: " .. targetRallied .. " " .. targetDisplay)
                end
                
                -- Check if target is met (but DON'T claim here)
                local targetMet = false
                if targetMode == "Equals" then
                    targetMet = (currentRallied == targetRallied)
                else -- GreaterThan
                    targetMet = (currentRallied >= targetRallied)
                end
                
                -- If target met, print to console but let the main toggle handle claiming
                if targetMet then
                    print("🎯 Target reached! Current: " .. currentRallied .. " | Target: " .. targetRallied)
                    print("⚠️ Use the 'Auto Claim When Target Met' toggle to claim")
                end
            end)
            
            -- Wait based on slider value
            task.wait(MonitorSpeedSlider.CurrentValue)
        end
    end)
end

local function StopRanchMonitoring()
    isMonitoringRanch = false
    print("⏹️ Ranch monitoring stopped")
end

-- Function to only fetch getRallied data
local function FetchRallyData()
    if not REQEvent then
        print("❌ REQ Remote not found!")
        return
    end
    
    if playerKey == "" then
        print("⚠️ Please enter your key first!")
        return
    end
    
    print("📊 Fetching ALL rally data...")
    
    local success, err = pcall(function()
        -- This is JUST getRallied, not the full sequence
        local getRalliedResult = REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "getRallied"
        )
        
        if getRalliedResult then
            rallyData = getRalliedResult
            print("✅ ALL rally data received")
            updateRallyDataDisplay()
            
            local totalLines = #formatDataForDisplay(rallyData)
            
            Rayfield:Notify({
                Title = "DATA FETCHED",
                Content = "Loaded " .. totalLines .. " lines of data",
                Duration = 3,
                Image = "database"
            })
        else
            print("❌ No data received")
            Rayfield:Notify({
                Title = "FETCH FAILED",
                Content = "No data received from server",
                Duration = 3,
                Image = "alert-circle"
            })
        end
    end)
    
    if not success then
        print("❌ Failed to fetch data: " .. tostring(err))
        Rayfield:Notify({
            Title = "ERROR",
            Content = "Failed to fetch rally data",
            Duration = 3,
            Image = "alert-triangle"
        })
    end
end

