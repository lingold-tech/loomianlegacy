-- Load the Rayfield Library
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Create the main window with Bloom theme
local Window = Rayfield:CreateWindow({
    Name = "Koontang is fat",
    LoadingTitle = "Loading Koontang is fat...",
    LoadingSubtitle = "REQ Double Hook Method",
    Theme = "Bloom",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "KoontangIsFatConfig",
        FileName = "Settings"
    },
    Discord = {
        Enabled = false,
        Invite = "noinvitelink",
        RememberJoins = true
    },
    KeySystem = false
})

-- Create tabs
local Tab = Window:CreateTab("Auto Rally", 4483362458)
local GrabberTab = Window:CreateTab("Key Grabber", 4483362458)

-- Variables
local isAutoRallyEnabled = false
local loopConnection = nil
local REQEvent = game:GetService("ReplicatedStorage").Remote.REQ
local playerKey = ""
local capturedKey = ""

-- ========== DOUBLE HOOK METHOD FOR REQ ==========
local function SetupDoubleHookREQ()
    print("🔄 Initializing Double Hook Method for REQ...")
    
    -- First hook: Metamethod hook for __namecall (InvokeServer)
    local mtHook; mtHook = hookmetamethod(game, "__namecall", function(...)
        local self = ...
        local method = getnamecallmethod()
        
        if rawequal(self, REQEvent) and method == "InvokeServer" then
            local Args = table.pack(...)
            
            -- Call original first
            local Result = table.pack(
                mtHook(self, table.unpack(Args, 1, Args.n))
            )
            
            -- Log the intercepted data
            print("🔥 DOUBLE HOOK 1 - __namecall intercepted REQ!")
            print("Method: InvokeServer")
            for i = 1, Args.n do
                print("Arg " .. i .. ":", Args[i])
                print("Arg " .. i .. " type:", type(Args[i]))
                if type(Args[i]) == "string" and #Args[i] > 10 then
                    capturedKey = Args[i]
                    print("✅ KEY CAPTURED: " .. capturedKey)
                    KeyInput:Set(capturedKey)
                end
            end
            print("================================")
            
            return table.unpack(Result, 1, Result.n)
        end
        
        return mtHook(...)
    end)
    
    -- Second hook: Direct InvokeServer hook
    local OldInvokeServer; OldInvokeServer = hookfunction(REQEvent.InvokeServer, function(...)
        local self = ...
        
        if rawequal(self, REQEvent) then
            local Args = table.pack(...)
            
            -- Call original
            local Result = table.pack(
                OldInvokeServer(table.unpack(Args, 1, Args.n))
            )
            
            -- Log the intercepted data
            print("🔥 DOUBLE HOOK 2 - Direct InvokeServer intercepted!")
            for i = 1, Args.n do
                print("Arg " .. i .. ":", Args[i])
                print("Arg " .. i .. " type:", type(Args[i]))
                if type(Args[i]) == "string" and #Args[i] > 10 then
                    capturedKey = Args[i]
                    print("✅ KEY CAPTURED: " .. capturedKey)
                    KeyInput:Set(capturedKey)
                end
            end
            print("================================")
            
            return table.unpack(Result, 1, Result.n)
        end
        
        return OldInvokeServer(self, ...)
    end)
    
    print("✅ Double Hook for REQ activated!")
    print("📋 Now use the rally feature and check console (F9)")
end

-- Alternative: Monitor all REQ calls
local function MonitorREQCalls()
    print("👁️ Monitoring all REQ calls...")
    
    -- Simple hook to just log without modifying
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if self == REQEvent and method == "InvokeServer" then
            print("📡 REQ Call Detected!")
            for i, v in ipairs(args) do
                print("  Arg" .. i .. ": " .. tostring(v))
                if type(v) == "string" and #v > 10 then
                    capturedKey = v
                    print("🎯 KEY FOUND: " .. v)
                    KeyInput:Set(v)
                end
            end
        end
        
        return oldNamecall(self, ...)
    end)
    
    print("✅ REQ Monitor activated!")
end

-- UI for Key Grabber tab
local ActivateButton = GrabberTab:CreateButton({
    Name = "Activate Double Hook (REQ)",
    Callback = function()
        SetupDoubleHookREQ()
    end
})

local MonitorButton = GrabberTab:CreateButton({
    Name = "Simple REQ Monitor",
    Callback = function()
        MonitorREQCalls()
    end
})

local ClearButton = GrabberTab:CreateButton({
    Name = "Clear Console",
    Callback = function()
        for i = 1, 50 do print("") end
        print("=== CONSOLE CLEARED ===")
    end
})

local Instructions = GrabberTab:CreateLabel("INSTRUCTIONS:")
local Step1 = GrabberTab:CreateLabel("1. Click 'Activate Double Hook (REQ)'")
local Step2 = GrabberTab:CreateLabel("2. Open Console (F9)")
local Step3 = GrabberTab:CreateLabel("3. Use the rally feature in-game")
local Step4 = GrabberTab:CreateLabel("4. Look for 'KEY CAPTURED' in console")
local Step5 = GrabberTab:CreateLabel("5. Key will auto-fill below")

-- ========== AUTO RALLY SECTION ==========
local function ExecuteRally()
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ No key available! Use Key Grabber first.")
        return
    end
    
    print("🚀 Executing rally with key: " .. keyToUse)
    
    local success, err = pcall(function()
        REQEvent:InvokeServer(
            keyToUse,
            "PDS",
            "handleRallied",
            {
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2
            }
        )
    end)
    
    if success then
        print("✅ Rally executed at: " .. os.date("%H:%M:%S"))
    else
        print("❌ Rally failed: " .. tostring(err))
    end
end

local function StartAutoRally(interval)
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ No key available! Use Key Grabber first.")
        AutoRallyToggle:Set(false)
        return
    end
    
    if loopConnection then
        loopConnection:Disconnect()
    end
    
    isAutoRallyEnabled = true
    print("▶️ Auto Rally started with key: " .. keyToUse)
    
    task.spawn(function()
        while isAutoRallyEnabled do
            ExecuteRally()
            task.wait(interval)
        end
    end)
end

local function StopAutoRally()
    isAutoRallyEnabled = false
    if loopConnection then
        loopConnection:Disconnect()
        loopConnection = nil
    end
    print("⏹️ Auto Rally stopped")
end

-- Auto Rally UI
local KeyInput = Tab:CreateInput({
    Name = "Enter Your Key (or capture with Grabber)",
    PlaceholderText = "Key will auto-fill when captured",
    RemoveTextAfterFocusLost = false,
    Flag = "PlayerKey",
    Callback = function(Text)
        playerKey = Text
        print("🔑 Manual key set to: " .. Text)
    end
})

local CurrentKeyLabel = Tab:CreateLabel("Current Key: None")
local CapturedKeyLabel = Tab:CreateLabel("Captured Key: None")

local IntervalSlider = Tab:CreateSlider({
    Name = "Interval (seconds)",
    Range = {0.1, 10},
    Increment = 0.1,
    CurrentValue = 2,
    Flag = "IntervalSetting"
})

local AutoRallyToggle = Tab:CreateToggle({
    Name = "Auto Rally",
    CurrentValue = false,
    Flag = "AutoRallyToggle",
    Callback = function(Value)
        if Value then
            StartAutoRally(IntervalSlider.CurrentValue)
        else
            StopAutoRally()
        end
    end
})

local ManualButton = Tab:CreateButton({
    Name = "Execute Once",
    Callback = function()
        ExecuteRally()
    end
})

local TestKeyButton = Tab:CreateButton({
    Name = "Test Current Key",
    Callback = function()
        local keyToUse = playerKey ~= "" and playerKey or capturedKey
        if keyToUse ~= "" then
            print("🔑 Current active key: " .. keyToUse)
            print("📏 Key length: " .. #keyToUse)
        else
            print("⚠️ No key available")
        end
    end
})

-- Update status labels
task.spawn(function()
    while true do
        if capturedKey ~= "" then
            CapturedKeyLabel:Set("Captured Key: " .. string.sub(capturedKey, 1, 20) .. "...")
        end
        if playerKey ~= "" then
            CurrentKeyLabel:Set("Current Key: " .. string.sub(playerKey, 1, 20) .. "...")
        end
        task.wait(1)
    end
end)

-- Load configuration
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
playerKey = KeyInput.CurrentValue or ""
if playerKey ~= "" then
    print("💾 Loaded saved key: " .. playerKey)
end
