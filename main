BattleTab:CreateToggle({
    Name = "🌿 AUTO-SPAWN WILD BATTLES",
    CurrentValue = false,
    Flag = "WildBattle",
    Callback = function(Value)
        WildBattleToggle = Value
        if Value then
            if not Main then
                for _,v in pairs(getgc(true)) do
                    if typeof(v) == "table" and rawget(v, "DataManager") then
                        Main = v
                        break
                    end
                end
            end
            
            if Main then
                print("🌿 [CONSOLE] Wild battle spawner activated")
                Rayfield:Notify({
                    Title = "BATTLE SPAWNER",
                    Content = "Wild battle spawner activated",
                    Duration = 3,
                    Image = "swords"
                })
            else
                print("❌ [CONSOLE] Could not find game data table")
                Rayfield:Notify({
                    Title = "ERROR",
                    Content = "Could not find game data table",
                    Duration = 5,
                    Image = "alert-triangle"
                })
                WildBattleToggle = false
            end
        else
            print("🌿 [CONSOLE] Wild battle spawner deactivated")
            Rayfield:Notify({
                Title = "BATTLE SPAWNER",
                Content = "Wild battle spawner deactivated",
                Duration = 3,
                Image = "circle-slash"
            })
        end
    end
})

BattleTab:CreateToggle({
    Name = "⏩ BATTLE FAST-FORWARD",
