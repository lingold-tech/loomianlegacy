-- Load the Rayfield Library
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Create the main window with Bloom theme
local Window = Rayfield:CreateWindow({
    Name = "Koontang is fat",
    LoadingTitle = "Loading Koontang is fat...",
    LoadingSubtitle = "Fixed Hook Method",
    Theme = "Bloom",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "KoontangIsFatConfig",
        FileName = "Settings"
    },
    Discord = {
        Enabled = false,
        Invite = "noinvitelink",
        RememberJoins = true
    },
    KeySystem = false
})

-- Create tabs
local Tab = Window:CreateTab("Auto Rally", 4483362458)
local GrabberTab = Window:CreateTab("Key Grabber", 4483362458)

-- Variables
local isAutoRallyEnabled = false
local loopConnection = nil
local REQEvent = game:GetService("ReplicatedStorage").Remote.REQ
local playerKey = ""
local capturedKey = ""

-- ========== FIXED HOOK METHOD (WON'T BREAK RETURNS) ==========
local function SetupFixedHook()
    print("🔄 Initializing Fixed Hook Method...")
    
    -- Store original
    local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        -- Get method and args
        local method = getnamecallmethod()
        local args = {...}
        
        -- Call original FIRST and store results
        local results = {oldNamecall(self, ...)}
        
        -- Only do our logging AFTER the original call
        if self == REQEvent and method == "InvokeServer" then
            -- Use pcall to prevent any errors from affecting the game
            pcall(function()
                print("📡 REQ Intercepted (Post-Call)")
                for i = 1, #args do
                    print("  Arg" .. i .. ": " .. tostring(args[i]))
                    if type(args[i]) == "string" and #args[i] > 10 then
                        capturedKey = args[i]
                        print("✅ KEY CAPTURED: " .. capturedKey)
                        -- Update UI safely
                        pcall(function()
                            KeyInput:Set(capturedKey)
                        end)
                    end
                end
            end)
        end
        
        -- Return original results exactly as they were
        return unpack(results)
    end)
    
    print("✅ Fixed Hook activated - Returns won't break!")
end

-- Even simpler: Just log to console without any UI updates
local function SetupSafeLogger()
    print("📝 Setting up safe logger...")
    
    local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        local results = {oldNamecall(self, ...)}
        
        if self == REQEvent and method == "InvokeServer" then
            -- Just print, no UI updates
            print("🔍 REQ Called with args:", unpack(args))
        end
        
        return unpack(results)
    end)
    
    print("✅ Safe logger active")
end

-- UI for Key Grabber tab
local FixedHookButton = GrabberTab:CreateButton({
    Name = "Activate Fixed Hook (Safe)",
    Callback = function()
        SetupFixedHook()
    end
})

local SafeLoggerButton = GrabberTab:CreateButton({
    Name = "Safe Logger Only",
    Callback = function()
        SetupSafeLogger()
    end
})

local ClearButton = GrabberTab:CreateButton({
    Name = "Clear Console",
    Callback = function()
        for i = 1, 30 do print("") end
    end
})

local Instructions = GrabberTab:CreateLabel("INSTRUCTIONS:")
local Step1 = GrabberTab:CreateLabel("1. Click 'Activate Fixed Hook'")
local Step2 = GrabberTab:CreateLabel("2. Use rally feature normally")
local Step3 = GrabberTab:CreateLabel("3. Key will be captured safely")

-- ========== AUTO RALLY SECTION ==========
local function ExecuteRally()
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ No key available! Use Key Grabber first.")
        return
    end
    
    -- Use pcall to prevent crashes
    local success, err = pcall(function()
        REQEvent:InvokeServer(
            keyToUse,
            "PDS",
            "handleRallied",
            {2, 2, 2, 2, 2, 2, 2, 2, 2}
        )
    end)
    
    if success then
        print("✅ Rally executed at: " .. os.date("%H:%M:%S"))
    else
        print("❌ Rally failed: " .. tostring(err))
    end
end

local function StartAutoRally(interval)
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ No key available! Use Key Grabber first.")
        AutoRallyToggle:Set(false)
        return
    end
    
    isAutoRallyEnabled = true
    print("▶️ Auto Rally started - Interval: " .. interval .. "s")
    
    task.spawn(function()
        while isAutoRallyEnabled do
            ExecuteRally()
            task.wait(interval)
        end
    end)
end

local function StopAutoRally()
    isAutoRallyEnabled = false
    print("⏹️ Auto Rally stopped")
end

-- Auto Rally UI
local KeyInput = Tab:CreateInput({
    Name = "Your Key",
    PlaceholderText = "Key will appear here",
    RemoveTextAfterFocusLost = false,
    Flag = "PlayerKey",
    Callback = function(Text)
        playerKey = Text
    end
})

local IntervalSlider = Tab:CreateSlider({
    Name = "Interval (seconds)",
    Range = {0.1, 10},
    Increment = 0.1,
    CurrentValue = 2,
    Flag = "IntervalSetting"
})

local AutoRallyToggle = Tab:CreateToggle({
    Name = "Auto Rally",
    CurrentValue = false,
    Flag = "AutoRallyToggle",
    Callback = function(Value)
        if Value then
            StartAutoRally(IntervalSlider.CurrentValue)
        else
            StopAutoRally()
        end
    end
})

local ManualButton = Tab:CreateButton({
    Name = "Execute Once",
    Callback = function()
        ExecuteRally()
    end
})

-- Load configuration
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
playerKey = KeyInput.CurrentValue or ""
if playerKey ~= "" then
    print("💾 Loaded saved key")
end
