-- ========== MAIN AUTO BATTLE LOOP ==========
task.spawn(function()
    while true do
        task.wait()

        if not AutoBattleEnabled then continue end

        local BattleGui = PlayerGui:FindFirstChild("BattleGui", true)
        if not BattleGui then continue end

        -- 🛑 Rare → RUN
        if isRarePokemon() then
            for _, v in ipairs(BattleGui:GetChildren()) do
                if v:IsA("ImageLabel") and v.ImageColor3 == Color3.fromRGB(218,83,255) then
                    clickButton(v:FindFirstChild("Button"))
                end
            end
            continue
        end

        -- Buttons
        local fightBtn, restBtn
        for _, v in ipairs(BattleGui:GetChildren()) do
            if v:IsA("ImageLabel") then
                if v.ImageColor3 == Color3.fromRGB(255,102,102) then
                    fightBtn = v:FindFirstChild("Button")
                elseif v.ImageColor3 == Color3.fromRGB(218,83,255) then
                    restBtn = v:FindFirstChild("Button")
                end
            end
        end

        -- Moves
        local m1 = BattleGui:FindFirstChild("Move1", true)
        local m2 = BattleGui:FindFirstChild("Move2", true)
        local m3 = BattleGui:FindFirstChild("Move3", true)
        local m4 = BattleGui:FindFirstChild("Move4", true)

        m1 = m1 and m1.Button
        m2 = m2 and m2.Button
        m3 = m3 and m3.Button
        m4 = m4 and m4.Button

        -- Start fight
        if fightBtn and fightBtn.Parent.Visible then
            clickButton(fightBtn)
            task.wait(0.8)
        end

        -- Energy
        local energy = 0
        local txt = BattleGui:FindFirstChild("EnergyText", true)
        if txt then
            energy = tonumber(txt.Text:match("%d+")) or 0
        end

        -- Attack logic
        if energy >= maxEnergyMove then
            if Moves[3] and m3 then clickButton(m3)
            elseif Moves[1] and m1 then clickButton(m1)
            elseif Moves[2] and m2 then clickButton(m2)
            elseif Moves[4] and m4 then clickButton(m4)
            end
        elseif restBtn then
            clickButton(restBtn)
        end
    end
end)

-- ========== WILD BATTLE SPAWNER LOOP ==========
task.spawn(function()
    while task.wait(1) do
        pcall(function()
            if WildBattleToggle and Main and Main.DataManager and Main.DataManager.currentChunk and Main.DataManager.currentChunk.regionData and Main.DataManager.currentChunk.regionData.Grass then
                if Main.Battle and Main.Battle.currentBattle then
                    Main.Battle.currentBattle.BattleEnded:Fire()
                    Main.Battle.currentBattle = nil
                    task.wait(0.5)
                end
                if Main.Battle and Main.Battle.doWildBattle then
                    Main.Battle.doWildBattle(Main.Battle, Main.DataManager.currentChunk.regionData.Grass, {})
                end
            end
        end)
    end
end)

-- ========== BATTLE FAST-FORWARD LOOP ==========
task.spawn(function()
    while task.wait() do
        pcall(function()
            if FastForwardToggle and Main and Main.Battle and Main.Battle.currentBattle then
                Main.Battle.currentBattle.fastForward = true
            end
        end)
    end
end)

-- ========== MAIN HUNTING LOOP ==========
task.spawn(function()
    while task.wait() do
        pcall(function()
            if TeleportToggle and TeleportToggle.CurrentValue and not isInBattle() then
                local eggs = getEggs()
                for _, egg in ipairs(eggs) do
                    if not TeleportToggle.CurrentValue or isInBattle() then 
                        if isInBattle() then
                            Rayfield:Notify({
                                Title = "COMBAT DETECTED",
                                Content = "Teleportation paused",
                                Duration = 3,
                                Image = "swords"
                            })
                        end
                        break 
                    end
                    if egg and egg.Parent then
                        humanoid.RootPart.CFrame = CFrame.new(egg.Position)
                        task.wait(teleportRate)
                    end
                end
            end
        end)
    end
end)

-- Initialize
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
if KeyInput and KeyInput.CurrentValue then
    playerKey = KeyInput.CurrentValue
    if playerKey ~= "" then
        print("💾 Loaded saved key: " .. playerKey)
    end
end

-- Welcome Notification
task.wait(1)
Rayfield:Notify({
   Title = "OWNER SYSTEM ONLINE",
   Content = "Premium controls activated\nAuto Rally + Auto Battle",
   Duration = 6,
   Image = "shield-check"
})
