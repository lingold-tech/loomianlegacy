-- Load the Rayfield Library
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Create the main window with Bloom theme
local Window = Rayfield:CreateWindow({
    Name = "Koontang is fat",
    LoadingTitle = "Loading Koontang is fat...",
    LoadingSubtitle = "Safe REQ Hook",
    Theme = "Bloom",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "KoontangIsFatConfig",
        FileName = "Settings"
    },
    Discord = {
        Enabled = false,
        Invite = "noinvitelink",
        RememberJoins = true
    },
    KeySystem = false
})

-- Create tabs
local Tab = Window:CreateTab("Auto Rally", 4483362458)
local GrabberTab = Window:CreateTab("Key Grabber", 4483362458)

-- Variables
local isAutoRallyEnabled = false
local loopConnection = nil
local REQEvent = game:GetService("ReplicatedStorage").Remote.REQ
local playerKey = ""
local capturedKey = ""
local hookActive = false

-- ========== SAFE KEY GRABBER (NO CRASH) ==========
local function SetupSafeKeyGrabber()
    if hookActive then
        print("⚠️ Hook already active!")
        return
    end
    
    print("🔄 Activating Safe Key Grabber...")
    hookActive = true
    
    -- Store original functions
    local oldNamecall
    local oldInvokeServer
    
    -- Use pcall to prevent crashes
    local success, result = pcall(function()
        -- Single hook method (safer than double hook)
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local success, result = pcall(function()
                local method = getnamecallmethod()
                local args = {...}
                
                -- Check if this is our target
                if self == REQEvent and method == "InvokeServer" then
                    print("📡 REQ Intercepted!")
                    for i = 1, #args do
                        print("  Arg" .. i .. ": " .. tostring(args[i]))
                        -- Look for long strings (keys)
                        if type(args[i]) == "string" and #args[i] > 10 then
                            capturedKey = args[i]
                            print("✅ KEY FOUND: " .. capturedKey)
                            
                            -- Safely update UI
                            pcall(function()
                                KeyInput:Set(capturedKey)
                                StatusLabel:Set("✅ Key captured!")
                            end)
                        end
                    end
                end
            end)
            
            -- Always call original, even if our code fails
            return oldNamecall(self, ...)
        end)
    end)
    
    if success then
        print("✅ Safe Key Grabber activated!")
        print("📋 Use the rally feature now...")
    else
        print("❌ Failed to activate: " .. tostring(result))
        hookActive = false
    end
end

-- Even safer: Just log without modifying anything
local function SetupLoggerOnly()
    print("📝 Activating Logger Only Mode...")
    
    -- This just prints but doesn't interfere
    local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        
        -- Log but don't process args heavily
        if self == REQEvent and method == "InvokeServer" then
            print("🔍 REQ InvokeServer detected")
        end
        
        return oldNamecall(self, ...)
    end)
    
    print("✅ Logger activated - check console for 'REQ InvokeServer detected'")
end

-- UI for Key Grabber tab
local SafeHookButton = GrabberTab:CreateButton({
    Name = "Activate Safe Key Grabber",
    Callback = function()
        SetupSafeKeyGrabber()
    end
})

local LoggerButton = GrabberTab:CreateButton({
    Name = "Logger Only (Safer)",
    Callback = function()
        SetupLoggerOnly()
    end
})

local ClearButton = GrabberTab:CreateButton({
    Name = "Clear Console",
    Callback = function()
        for i = 1, 30 do print("") end
        print("=== CONSOLE CLEARED ===")
    end
})

local StatusLabel = GrabberTab:CreateLabel("Status: Inactive")

-- ========== AUTO RALLY SECTION ==========
local function ExecuteRally()
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ No key available! Use Key Grabber first.")
        return
    end
    
    -- Use pcall to prevent crashes
    local success, err = pcall(function()
        REQEvent:InvokeServer(
            keyToUse,
            "PDS",
            "handleRallied",
            {2, 2, 2, 2, 2, 2, 2, 2, 2}
        )
    end)
    
    if success then
        print("✅ Rally executed at: " .. os.date("%H:%M:%S"))
    else
        print("❌ Rally failed: " .. tostring(err))
    end
end

local function StartAutoRally(interval)
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ No key available! Use Key Grabber first.")
        AutoRallyToggle:Set(false)
        return
    end
    
    isAutoRallyEnabled = true
    print("▶️ Auto Rally started - Interval: " .. interval .. "s")
    
    -- Use simple task.wait loop
    task.spawn(function()
        while isAutoRallyEnabled do
            ExecuteRally()
            task.wait(interval)
        end
    end)
end

local function StopAutoRally()
    isAutoRallyEnabled = false
    print("⏹️ Auto Rally stopped")
end

-- Auto Rally UI
local KeyInput = Tab:CreateInput({
    Name = "Your Key",
    PlaceholderText = "Key will appear here when captured",
    RemoveTextAfterFocusLost = false,
    Flag = "PlayerKey",
    Callback = function(Text)
        playerKey = Text
        print("🔑 Manual key: " .. Text)
    end
})

local IntervalSlider = Tab:CreateSlider({
    Name = "Interval (seconds)",
    Range = {0.1, 10},
    Increment = 0.1,
    CurrentValue = 2,
    Flag = "IntervalSetting"
})

local AutoRallyToggle = Tab:CreateToggle({
    Name = "Auto Rally",
    CurrentValue = false,
    Flag = "AutoRallyToggle",
    Callback = function(Value)
        if Value then
            StartAutoRally(IntervalSlider.CurrentValue)
        else
            StopAutoRally()
        end
    end
})

local ManualButton = Tab:CreateButton({
    Name = "Execute Once",
    Callback = function()
        ExecuteRally()
    end
})

local ShowKeyButton = Tab:CreateButton({
    Name = "Show Current Key",
    Callback = function()
        if capturedKey ~= "" then
            print("🔑 Captured key: " .. capturedKey)
        elseif playerKey ~= "" then
            print("🔑 Manual key: " .. playerKey)
        else
            print("⚠️ No key available")
        end
    end
})

-- Load configuration
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
playerKey = KeyInput.CurrentValue or ""
if playerKey ~= "" then
    print("💾 Loaded saved key")
end
