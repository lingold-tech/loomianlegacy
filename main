-- Load the Rayfield Library
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Create the main window with Bloom theme
local Window = Rayfield:CreateWindow({
    Name = "Koontang is fat",
    LoadingTitle = "Loading Koontang is fat...",
    LoadingSubtitle = "ULTRA SAFE METHOD",
    Theme = "Bloom",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "KoontangIsFatConfig",
        FileName = "Settings"
    },
    Discord = {
        Enabled = false,
        Invite = "noinvitelink",
        RememberJoins = true
    },
    KeySystem = false
})

-- Create tabs
local Tab = Window:CreateTab("Auto Rally", 4483362458)
local GrabberTab = Window:CreateTab("Key Grabber", 4483362458)

-- Variables
local isAutoRallyEnabled = false
local REQEvent = game:GetService("ReplicatedStorage").Remote.REQ
local playerKey = ""
local capturedKey = ""

-- ========== ULTRA SAFE METHOD - NO HOOKS ==========
-- Instead of hooks, we'll just scan memory periodically
local function ScanForKeys()
    print("🔍 Scanning for keys in memory...")
    
    -- Check recent logs (if any)
    local success, result = pcall(function()
        -- Look for any strings in the game that might be keys
        local function findStrings(obj, depth)
            if depth > 3 then return end
            
            for _, child in pairs(obj:GetChildren()) do
                -- Check string values
                if child:IsA("StringValue") and #child.Value > 10 then
                    print("Found potential key: " .. child.Value)
                    if capturedKey == "" then
                        capturedKey = child.Value
                        KeyInput:Set(capturedKey)
                    end
                end
                
                -- Check object names
                if #child.Name > 15 then
                    print("Found long name: " .. child.Name)
                end
                
                findStrings(child, depth + 1)
            end
        end
        
        findStrings(game:GetService("ReplicatedStorage"), 0)
    end)
    
    print("✅ Scan complete!")
end

-- Even safer: Just let user paste the key manually
local function ManualMode()
    print("📝 Manual Mode - Just paste your key in the input box")
    print("If you don't have the key, try:")
    print("1. Looking in other scripts")
    print("2. Asking other players")
    print("3. Checking game Discord")
end

-- UI for Key Grabber tab - NO HOOKS AT ALL
local ScanButton = GrabberTab:CreateButton({
    Name = "Scan for Keys (Safe)",
    Callback = function()
        ScanForKeys()
    end
})

local ManualModeButton = GrabberTab:CreateButton({
    Name = "Manual Entry Mode",
    Callback = function()
        ManualMode()
    end
})

local ClearButton = GrabberTab:CreateButton({
    Name = "Clear Console",
    Callback = function()
        for i = 1, 30 do print("") end
    end
})

local Instructions = GrabberTab:CreateLabel("INSTRUCTIONS:")
local Step1 = GrabberTab:CreateLabel("OPTION 1: Click 'Scan for Keys'")
local Step2 = GrabberTab:CreateLabel("OPTION 2: Type key manually")
local Step3 = GrabberTab:CreateLabel("OPTION 3: Ask other players for key")
local Warning = GrabberTab:CreateLabel("⚠️ NO HOOKS = NO CRASHES")

-- ========== AUTO RALLY SECTION ==========
local function ExecuteRally()
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ Please enter your key first!")
        return
    end
    
    print("🚀 Executing rally...")
    
    local success, err = pcall(function()
        REQEvent:InvokeServer(
            keyToUse,
            "PDS",
            "handleRallied",
            {2, 2, 2, 2, 2, 2, 2, 2, 2}
        )
    end)
    
    if success then
        print("✅ Rally executed at: " .. os.date("%H:%M:%S"))
    else
        print("❌ Rally failed: " .. tostring(err))
    end
end

local function StartAutoRally(interval)
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ Please enter your key first!")
        AutoRallyToggle:Set(false)
        return
    end
    
    isAutoRallyEnabled = true
    print("▶️ Auto Rally started - Interval: " .. interval .. "s")
    
    task.spawn(function()
        while isAutoRallyEnabled do
            ExecuteRally()
            task.wait(interval)
        end
    end)
end

local function StopAutoRally()
    isAutoRallyEnabled = false
    print("⏹️ Auto Rally stopped")
end

-- Auto Rally UI
local KeyInput = Tab:CreateInput({
    Name = "Enter Your Key",
    PlaceholderText = "Paste your key here...",
    RemoveTextAfterFocusLost = false,
    Flag = "PlayerKey",
    Callback = function(Text)
        playerKey = Text
        print("🔑 Key set to: " .. Text)
    end
})

local IntervalSlider = Tab:CreateSlider({
    Name = "Interval (seconds)",
    Range = {0.1, 10},
    Increment = 0.1,
    CurrentValue = 2,
    Flag = "IntervalSetting"
})

local AutoRallyToggle = Tab:CreateToggle({
    Name = "Auto Rally",
    CurrentValue = false,
    Flag = "AutoRallyToggle",
    Callback = function(Value)
        if Value then
            StartAutoRally(IntervalSlider.CurrentValue)
        else
            StopAutoRally()
        end
    end
})

local ManualButton = Tab:CreateButton({
    Name = "Execute Once",
    Callback = function()
        ExecuteRally()
    end
})

-- Load configuration
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
playerKey = KeyInput.CurrentValue or ""
if playerKey ~= "" then
    print("💾 Loaded saved key: " .. playerKey)
end
