RallyTab:CreateSection("Auto Claim")

-- Auto Claim toggle (uses the strict 3-step sequence)
local AutoClaimToggle = RallyTab:CreateToggle({
    Name = "🎯 Auto Claim When Target Met",
    CurrentValue = false,
    Flag = "AutoClaimToggle",
    Callback = function(Value)
        if Value then
            if playerKey == "" then
                print("⚠️ Please enter your key first!")
                AutoClaimToggle:Set(false)
                return
            end
            print("🎯 Auto Claim enabled - Will use STRICT 3-step sequence when target reached")
            
            -- Spawn a separate thread for auto-claim checking
            task.spawn(function()
                while AutoClaimToggle.CurrentValue do
                    -- Check if target is met
                    local targetMet = false
                    if targetMode == "Equals" then
                        targetMet = (currentRallied == targetRallied)
                    else
                        targetMet = (currentRallied >= targetRallied)
                    end
                    
                    -- If target met and not in battle, execute strict claim sequence
                    if targetMet and not isInBattle() then
                        print("🎯 Target detected! Executing strict claim sequence...")
                        ExecuteStrictClaimSequence()
                        
                        -- Wait a bit after claiming to prevent multiple claims
                        task.wait(10)
                    end
                    
                    task.wait(2) -- Check every 2 seconds
                end
            end)
        else
            print("⏹️ Auto Claim disabled")
        end
    end
})

