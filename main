-- Combined Script: Auto Rally + Owner's Edition Features
local Rayfield

-- Try multiple ways to load Rayfield
local success, result = pcall(function()
    Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
end)

if not success or not Rayfield then
    success, result = pcall(function()
        Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua'))()
    end)
end

if not success or not Rayfield then
    warn("Failed to load Rayfield UI Library")
    return
end

local Window = Rayfield:CreateWindow({
   Name = "Koontang is fat",
   LoadingTitle = "Premium Egg Hunter + Auto Rally",
   LoadingSubtitle = "Owner's Edition",
   Theme = "Bloom",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "KoontangIsFatConfig",
      FileName = "Settings"
   },
   Discord = {
      Enabled = false,
      Invite = "noinvitelink",
      RememberJoins = true
   },
   KeySystem = false
})

-- Core Variables
local player = game:GetService("Players").LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local PlayerGui = player:WaitForChild("PlayerGui")
local musicId = 5410086218
local musicSound
local yLimit = 1000
local teleportRate = 0.39
local baseplate = nil
local AutoBattleEnabled = true
local Main = nil
local WildBattleToggle = false
local FastForwardToggle = false

-- Rally Variables
local isRallyRunning = false
local REQEvent = game:GetService("ReplicatedStorage"):FindFirstChild("Remote") and game:GetService("ReplicatedStorage").Remote:FindFirstChild("REQ")
local EVTEvent = game:GetService("ReplicatedStorage"):WaitForChild("Remote"):WaitForChild("EVT")
local playerKey = ""
local keyHookActive = false

-- Wild ID capture variable (only current battle)
local currentWildID = nil
local keyCaptured = false  -- flag to ensure key is only captured once

-- Safety check for REQ event
if not REQEvent then
    warn("REQ Remote not found! Auto Rally may not work.")
end

-- Clean up existing sounds
for _, sound in pairs(workspace:GetDescendants()) do
    if sound:IsA("Sound") then sound:Destroy() end
end

-- Music System
local function playMusic()
    if musicSound then musicSound:Stop() end
    musicSound = Instance.new("Sound")
    musicSound.Parent = workspace
    musicSound.SoundId = "rbxassetid://"..musicId
    musicSound.Looped = true
    musicSound.Volume = 0.5
    musicSound:Play()
end

-- Anti-lag system
local function optimizeGame()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        game.Lighting.GlobalShadows = false
        for _,v in pairs(game.Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                v.Enabled = false
            elseif v:IsA("BasePart") and v.Material == Enum.Material.Grass then
                v.Material = Enum.Material.SmoothPlastic
            end
        end
    end)
end

local function deactivateLag()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        game.Lighting.GlobalShadows = true
        for _,v in pairs(game.Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                v.Enabled = true
            end
        end
    end)
end

-- Battle Detection
local function isInBattle()
    return PlayerGui:FindFirstChild("BattleGui", true) ~= nil
end

-- Egg Detection System
local function getEggs()
    local eggs = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "Egg" and obj.Position.Y <= yLimit then
            table.insert(eggs, obj)
        end
    end
    return eggs
end

-- ========== RALLY SEQUENCE ==========
local function RunRallySequence()
    if not REQEvent then
        print("❌ REQ Remote not found!")
        return false
    end
    
    if playerKey == "" then
        print("⚠️ Please enter your key first!")
        return false
    end
    
    print("🚀 Running rally sequence at: " .. os.date("%H:%M:%S"))
    
    local success, err = pcall(function()
        -- Step 1: ranchStatus
        print("  Step 1: ranchStatus")
        REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "ranchStatus"
        )
        
        -- Step 2: getRallied
        print("  Step 2: getRallied")
        REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "getRallied"
        )
        
        -- Step 3: handleRallied (the actual claim)
        print("  Step 3: handleRallied")
        REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "handleRallied",
            {
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2
            }
        )
    end)
    
    if success then
        print("✅ Rally sequence completed at: " .. os.date("%H:%M:%S"))
        Rayfield:Notify({
            Title = "✅ RALLY CLAIMED",
            Content = "Successfully claimed rally!",
            Duration = 3,
            Image = "check-circle"
        })
        return true
    else
        print("❌ Sequence failed: " .. tostring(err))
        Rayfield:Notify({
            Title = "❌ CLAIM FAILED",
            Content = "Error: " .. tostring(err):sub(1, 50),
            Duration = 4,
            Image = "alert-triangle"
        })
        return false
    end
end

local function StartAutoRally(interval)
    isRallyRunning = true
    print("▶️ Auto Rally started - Running every " .. interval .. " minutes")
    
    task.spawn(function()
        while isRallyRunning do
            RunRallySequence()
            task.wait(interval * 60)
        end
    end)
end

local function StopAutoRally()
    isRallyRunning = false
    print("⏹️ Auto Rally stopped")
end

-- ========== AUTO KEY EXTRACTOR (hookfunction) WITH WILD ID CAPTURE ==========
local keyHookOriginal = nil

local function StartKeyExtractor(KeyInput)
    if keyHookActive then
        print("⚠️ Key extractor already running")
        return
    end

    local ok = pcall(function()
        keyHookOriginal = hookfunction(EVTEvent.FireServer, function(self, ...)
            local args = {...}
            -- Capture player key ONCE (only if not already captured)
            if not keyCaptured then
                for _, v in pairs(args) do
                    if typeof(v) == "string" and #v >= 20 then
                        playerKey = v
                        keyCaptured = true
                        print("🔑 [CONSOLE] Player key captured: " .. playerKey)
                        if KeyInput then
                            pcall(function() KeyInput:Set(v) end)
                        end
                        Rayfield:Notify({
                            Title = "🔑 KEY CAPTURED",
                            Content = playerKey:sub(1, 12) .. "...",
                            Duration = 4,
                            Image = "key"
                        })
                        break
                    end
                end
            end
            
            -- Capture wild loomian ID for each battle (overwrites previous)
            if args[2] == "BattleEvent" and args[4] == "join" then
                local wildID = args[3]
                if wildID and typeof(wildID) == "string" and #wildID > 5 then
                    currentWildID = wildID
                    print("🐾 [CONSOLE] Wild loomian ID captured (new battle): " .. currentWildID)
                    Rayfield:Notify({
                        Title = "🐾 WILD ID CAPTURED",
                        Content = "Opponent ID: " .. wildID:sub(1, 10) .. "...",
                        Duration = 3,
                        Image = "swords"
                    })
                end
            end
            
            return keyHookOriginal(self, ...)
        end)
    end)

    if ok then
        keyHookActive = true
        print("✅ Key extractor hook active (listening for key & wild IDs)")
        Rayfield:Notify({
            Title = "🔍 KEY EXTRACTOR ON",
            Content = "Listening for key & wild IDs...",
            Duration = 3,
            Image = "search"
        })
    else
        Rayfield:Notify({
            Title = "❌ HOOK FAILED",
            Content = "hookfunction not supported",
            Duration = 4,
            Image = "alert-triangle"
        })
    end
end

local function StopKeyExtractor()
    if not keyHookActive then return end
    if keyHookOriginal then
        pcall(function()
            hookfunction(EVTEvent.FireServer, keyHookOriginal)
        end)
    end
    keyHookActive = false
    print("⏹️ Key extractor stopped")
    Rayfield:Notify({
        Title = "🔍 KEY EXTRACTOR OFF",
        Content = "Hook removed",
        Duration = 2,
        Image = "x-circle"
    })
end

