-- Load the Rayfield Library
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Create the main window with Bloom theme
local Window = Rayfield:CreateWindow({
    Name = "Koontang is fat",
    LoadingTitle = "Loading Koontang is fat...",
    LoadingSubtitle = "ID Grabber Edition",
    Theme = "Bloom",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "KoontangIsFatConfig",
        FileName = "Settings"
    },
    Discord = {
        Enabled = false,
        Invite = "noinvitelink",
        RememberJoins = true
    },
    KeySystem = false
})

-- Create main tab
local Tab = Window:CreateTab("Main", 4483362458)
local IDTab = Window:CreateTab("ID Grabber", 4483362458) -- New tab for ID grabbing

-- Variables
local isAutoRallyEnabled = false
local loopConnection = nil
local Event = game:GetService("ReplicatedStorage").Remote.REQ
local playerKey = ""

-- ========== ID GRABBER SECTION ==========
local function SetupIDGrabber()
    -- Hook for REQ (your original event)
    local EventREQ = game:GetService("ReplicatedStorage").Remote.REQ
    local mtHook; mtHook = hookmetamethod(game, "__namecall", function(...)
        local self = ...
        
        if rawequal(self, EventREQ) and getnamecallmethod() == "InvokeServer" then
            local Args = table.pack(...)
            local Result = table.pack(mtHook(self, table.unpack(Args, 1, Args.n)))
            
            -- Print the intercepted arguments
            print("=== INTERCEPTED REQ ===")
            print("Method: InvokeServer")
            for i = 1, Args.n do
                print("Arg " .. i .. ":", Args[i])
            end
            print("=======================")
            
            -- Auto-fill the key input if we detect a pattern
            if type(Args[1]) == "string" and #Args[1] > 10 then
                playerKey = Args[1]
                KeyInput:Set(Args[1])
                print("✅ Key auto-filled: " .. Args[1])
            end
            
            return table.unpack(Result, 1, Result.n)
        end
        
        return mtHook(...)
    end)
    
    -- Hook for EVT (your new event)
    local EventEVT = game:GetService("ReplicatedStorage").Remote.EVT
    local mtHook2; mtHook2 = hookmetamethod(game, "__namecall", function(...)
        local self = ...
        
        if rawequal(self, EventEVT) and getnamecallmethod() == "FireServer" then
            local Args = table.pack(...)
            local Result = table.pack(mtHook2(self, table.unpack(Args, 1, Args.n)))
            
            -- Print the intercepted arguments
            print("=== INTERCEPTED EVT ===")
            print("Method: FireServer")
            for i = 1, Args.n do
                print("Arg " .. i .. ":", Args[i])
            end
            print("=======================")
            
            return table.unpack(Result, 1, Result.n)
        end
        
        return mtHook2(...)
    end)
    
    -- Also hook the FireServer method directly
    local OldFireServer = hookfunction(EventEVT.FireServer, function(...)
        local self = ...
        if rawequal(self, EventEVT) then
            local Args = table.pack(...)
            local Result = table.pack(OldFireServer(table.unpack(Args, 1, Args.n)))
            
            print("=== DIRECT FIRESERVER HOOK ===")
            for i = 1, Args.n do
                print("Arg " .. i .. ":", Args[i])
            end
            print("===============================")
            
            return table.unpack(Result, 1, Result.n)
        end
        return OldFireServer(self, ...)
    end)
    
    print("✅ ID Grabber activated! Check console (F9) for intercepted data")
end

-- Create ID Grabber UI
local IDGrabberTab = Window:CreateTab("ID Grabber", 4483362458)

local ActivateGrabber = IDGrabberTab:CreateButton({
    Name = "Activate ID Grabber",
    Callback = function()
        SetupIDGrabber()
    end
})

local Instructions = IDGrabberTab:CreateLabel("Instructions:")
local Step1 = IDGrabberTab:CreateLabel("1. Click 'Activate ID Grabber'")
local Step2 = IDGrabberTab:CreateLabel("2. Open console (F9)")
local Step3 = IDGrabberTab:CreateLabel("3. Execute the rally manually in-game")
local Step4 = IDGrabberTab:CreateLabel("4. Look for 'INTERCEPTED' messages")
local Step5 = IDGrabberTab:CreateLabel("5. Copy the ID/Key that appears")

local ClearConsole = IDGrabberTab:CreateButton({
    Name = "Clear Console",
    Callback = function()
        for i = 1, 50 do
            print(" ")
        end
        print("=== CONSOLE CLEARED ===")
    end
})

-- ========== AUTO RALLY SECTION ==========
-- Function to execute the rally
local function ExecuteRally()
    if playerKey == "" then
        print("⚠️ Please enter your key first!")
        return
    end
    
    local success, err = pcall(function()
        Event:InvokeServer(
            playerKey,
            "PDS",
            "handleRallied",
            {
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2
            }
        )
    end)
    
    if success then
        print("✅ Rally executed at: " .. os.date("%H:%M:%S"))
    else
        print("❌ Rally failed: " .. tostring(err))
    end
end

-- Function to start the loop
local function StartAutoRally(interval)
    if playerKey == "" then
        print("⚠️ Cannot start Auto Rally - Please enter your key first!")
        AutoRallyToggle:Set(false)
        return
    end
    
    if loopConnection then
        loopConnection:Disconnect()
    end
    
    loopConnection = game:GetService("RunService").Heartbeat:Connect(function()
        ExecuteRally()
        task.wait(interval)
    end)
end

-- Function to stop the loop
local function StopAutoRally()
    if loopConnection then
        loopConnection:Disconnect()
        loopConnection = nil
    end
    isAutoRallyEnabled = false
    print("⏹️ Auto Rally stopped")
end

-- Create input for player key
local KeyInput = Tab:CreateInput({
    Name = "Enter Your Key",
    PlaceholderText = "Key will appear here when grabbed",
    RemoveTextAfterFocusLost = false,
    Flag = "PlayerKey",
    Callback = function(Text)
        playerKey = Text
        print("🔑 Key saved: " .. Text)
    end
})

-- Create interval slider
local IntervalSlider = Tab:CreateSlider({
    Name = "Interval (seconds)",
    Range = {0.1, 10},
    Increment = 0.1,
    CurrentValue = 2,
    Flag = "IntervalSetting",
    Callback = function(Value)
        if isAutoRallyEnabled then
            StartAutoRally(Value)
        end
    end
})

-- Create toggle for auto rally
local AutoRallyToggle = Tab:CreateToggle({
    Name = "Auto Rally",
    CurrentValue = false,
    Flag = "AutoRallyToggle",
    Callback = function(Value)
        isAutoRallyEnabled = Value
        if Value then
            local interval = IntervalSlider.CurrentValue
            StartAutoRally(interval)
            print("▶️ Auto Rally started - Interval: " .. interval .. " seconds")
        else
            StopAutoRally()
        end
    end
})

-- Manual execute button
local ManualButton = Tab:CreateButton({
    Name = "Execute Once",
    Callback = function()
        ExecuteRally()
    end
})

-- Load configuration
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
playerKey = KeyInput.CurrentValue or ""
if AutoRallyToggle.CurrentValue and playerKey ~= "" then
    isAutoRallyEnabled = true
    StartAutoRally(IntervalSlider.CurrentValue)
end
