-- Load the Rayfield Library
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Create the main window with Bloom theme
local Window = Rayfield:CreateWindow({
    Name = "Koontang is fat",
    LoadingTitle = "Loading Koontang is fat...",
    LoadingSubtitle = "Fixed Version",
    Theme = "Bloom",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "KoontangIsFatConfig",
        FileName = "Settings"
    },
    Discord = {
        Enabled = false,
        Invite = "noinvitelink",
        RememberJoins = true
    },
    KeySystem = false
})

-- Create tabs
local Tab = Window:CreateTab("Auto Rally", 4483362458)
local GrabberTab = Window:CreateTab("Key Grabber", 4483362458)

-- Variables
local isAutoRallyEnabled = false
local REQEvent = game:GetService("ReplicatedStorage").Remote.REQ
local playerKey = ""
local capturedKey = ""

-- ========== SIMPLE KEY GRABBER (NO HOOKS) ==========
-- This just lets you manually enter the key
local function ManualKeyEntry()
    print("=== MANUAL KEY ENTRY ===")
    print("If you know your key, just type it in the input box")
    print("If you don't know it, try:")
    print("1. Check other scripts")
    print("2. Ask other players")
    print("3. Look in the game's Discord")
end

-- Alternative: Try to find key in game memory (safe)
local function ScanGameForKeys()
    print("🔍 Scanning game for potential keys...")
    local found = 0
    
    -- Check LocalPlayer for any strings
    local function checkObject(obj, name)
        if not obj then return end
        
        -- Check values
        if obj:IsA("StringValue") and #obj.Value > 10 then
            print("Found string in " .. name .. ": " .. obj.Value)
            found = found + 1
        end
        
        -- Check children
        for _, child in pairs(obj:GetChildren()) do
            checkObject(child, name .. "." .. child.Name)
        end
    end
    
    -- Start scanning from common locations
    checkObject(game.Players.LocalPlayer, "LocalPlayer")
    checkObject(game.ReplicatedStorage, "ReplicatedStorage")
    
    if found == 0 then
        print("No obvious keys found in memory")
    end
    print("Scan complete!")
end

-- UI for Key Grabber tab
local Instructions = GrabberTab:CreateLabel("HOW TO GET YOUR KEY:")
local Method1 = GrabberTab:CreateLabel("1. Ask other players for their key")
local Method2 = GrabberTab:CreateLabel("2. Check game Discord/community")
local Method3 = GrabberTab:CreateLabel("3. Look in other scripts you have")
local Method4 = GrabberTab:CreateLabel("4. Try common patterns")

local ScanButton = GrabberTab:CreateButton({
    Name = "Scan Game for Keys",
    Callback = function()
        ScanGameForKeys()
    end
})

local ClearButton = GrabberTab:CreateButton({
    Name = "Clear Console",
    Callback = function()
        for i = 1, 30 do print("") end
    end
})

-- ========== AUTO RALLY SECTION ==========
local function ExecuteRally()
    local keyToUse = playerKey ~= "" and playerKey or capturedKey
    
    if keyToUse == "" then
        print("⚠️ Please enter your key first!")
        return
    end
    
    print("🚀 Executing rally...")
    
    local success, err = pcall(function()
        REQEvent:InvokeServer(
            keyToUse,
            "PDS",
            "handleRallied",
            {2, 2, 2, 2, 2, 2, 2, 2, 2}
        )
    end)
    
    if success then
        print("✅ Rally executed at: " .. os.date("%H:%M:%S"))
    else
        print("❌ Rally failed: " .. tostring(err))
    end
end

local function StartAutoRally(interval)
    if playerKey == "" and capturedKey == "" then
        print("⚠️ Please enter your key first!")
        AutoRallyToggle:Set(false)
        return
    end
    
    isAutoRallyEnabled = true
    print("▶️ Auto Rally started - Interval: " .. interval .. "s")
    
    task.spawn(function()
        while isAutoRallyEnabled do
            ExecuteRally()
            task.wait(interval)
        end
    end)
end

local function StopAutoRally()
    isAutoRallyEnabled = false
    print("⏹️ Auto Rally stopped")
end

-- Auto Rally UI
local KeyInput = Tab:CreateInput({
    Name = "Enter Your Key",
    PlaceholderText = "Type your key here...",
    RemoveTextAfterFocusLost = false,
    Flag = "PlayerKey",
    Callback = function(Text)
        playerKey = Text
        print("🔑 Key set to: " .. Text)
    end
})

local IntervalSlider = Tab:CreateSlider({
    Name = "Interval (seconds)",
    Range = {0.1, 10},
    Increment = 0.1,
    CurrentValue = 2,
    Flag = "IntervalSetting"
})

local AutoRallyToggle = Tab:CreateToggle({
    Name = "Auto Rally",
    CurrentValue = false,
    Flag = "AutoRallyToggle",
    Callback = function(Value)
        if Value then
            StartAutoRally(IntervalSlider.CurrentValue)
        else
            StopAutoRally()
        end
    end
})

local ManualButton = Tab:CreateButton({
    Name = "Execute Once",
    Callback = function()
        ExecuteRally()
    end
})

-- Add a reset button in case menu breaks
local ResetButton = Tab:CreateButton({
    Name = "Reset UI (if frozen)",
    Callback = function()
        print("🔄 Attempting to reset...")
        AutoRallyToggle:Set(false)
        isAutoRallyEnabled = false
        print("✅ Reset complete")
    end
})

-- Load configuration
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
playerKey = KeyInput.CurrentValue or ""
if playerKey ~= "" then
    print("💾 Loaded saved key: " .. playerKey)
end
