            end
        else
            print("⏩ [CONSOLE] Battle fast-forward deactivated")
            Rayfield:Notify({
                Title = "BATTLE SPEED",
                Content = "Battle fast-forward deactivated",
                Duration = 3,
                Image = "clock"
            })
        end
