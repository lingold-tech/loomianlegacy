-- Combined Script: Auto Rally + Owner's Edition Features + Auto Battle
local Rayfield

-- Try multiple ways to load Rayfield
local success, result = pcall(function()
    Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
end)

if not success or not Rayfield then
    -- Fallback to a different URL
    success, result = pcall(function()
        Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua'))()
    end)
end

if not success or not Rayfield then
    warn("Failed to load Rayfield UI Library")
    return
end

local Window = Rayfield:CreateWindow({
   Name = "Koontang is fat",
   LoadingTitle = "Premium Egg Hunter + Auto Rally",
   LoadingSubtitle = "Owner's Edition",
   Theme = "Bloom",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "KoontangIsFatConfig",
      FileName = "Settings"
   },
   Discord = {
      Enabled = false,
      Invite = "noinvitelink",
      RememberJoins = true
   },
   KeySystem = false
})

-- Core Variables
local player = game:GetService("Players").LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local PlayerGui = player:WaitForChild("PlayerGui")
local musicId = 5410086218
local musicSound
local yLimit = 1000
local teleportRate = 0.39
local baseplate = nil
local WildBattleToggle = false
local FastForwardToggle = false

-- Rally Variables
local isRallyRunning = false
local rallyLoop = nil
local REQEvent = game:GetService("ReplicatedStorage"):FindFirstChild("Remote") and game:GetService("ReplicatedStorage").Remote:FindFirstChild("REQ")
local playerKey = ""

-- Auto Battle Settings
_G.Move = "move 2"

-- Safety check for REQ event
if not REQEvent then
    warn("REQ Remote not found! Auto Rally may not work.")
end

-- Clean up existing sounds
for _, sound in pairs(workspace:GetDescendants()) do
    if sound:IsA("Sound") then sound:Destroy() end
end

-- Music System
local function playMusic()
    if musicSound then musicSound:Stop() end
    musicSound = Instance.new("Sound")
    musicSound.Parent = workspace
    musicSound.SoundId = "rbxassetid://"..musicId
    musicSound.Looped = true
    musicSound.Volume = 0.5
    musicSound:Play()
end

-- Anti-lag system
local function optimizeGame()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        game.Lighting.GlobalShadows = false
        for _,v in pairs(game.Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                v.Enabled = false
            elseif v:IsA("BasePart") and v.Material == Enum.Material.Grass then
                v.Material = Enum.Material.SmoothPlastic
            end
        end
    end)
end

local function deactivateLag()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        game.Lighting.GlobalShadows = true
        for _,v in pairs(game.Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                v.Enabled = true
            end
        end
    end)
end

-- Battle Detection
local function isInBattle()
    return PlayerGui:FindFirstChild("BattleGui", true) ~= nil
end

-- Egg Detection System
local function getEggs()
    local eggs = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "Egg" and obj.Position.Y <= yLimit then
            table.insert(eggs, obj)
        end
    end
    return eggs
end

-- ========== RALLY SEQUENCE ==========
local function RunRallySequence()
    if not REQEvent then
        print("❌ REQ Remote not found!")
        return false
    end
    
    if playerKey == "" then
        print("⚠️ No key entered - skipping claim")
        return false
    end
    
    print("🚀 Running rally sequence at: " .. os.date("%H:%M:%S"))
    print("  🔑 Using key: " .. playerKey)
    
    -- Show prompt before claiming
    Rayfield:Notify({
        Title = "🎯 RALLY READY",
        Content = "Preparing to claim rally...",
        Duration = 2,
        Image = "alert-circle"
    })
    
    local success, err = pcall(function()
        -- Step 1: ranchStatus
        print("  Step 1: ranchStatus")
        REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "ranchStatus"
        )
        
        -- Brief pause between steps
        task.wait(0.5)
        
        -- Step 2: getRallied
        print("  Step 2: getRallied")
        REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "getRallied"
        )
        
        -- Brief pause between steps
        task.wait(0.5)
        
        -- Step 3: handleRallied (the actual claim)
        print("  Step 3: handleRallied")
        REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "handleRallied",
            {
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2
            }
        )
    end)
    
    if success then
        print("✅ Rally sequence completed at: " .. os.date("%H:%M:%S"))
        Rayfield:Notify({
            Title = "✅ RALLY CLAIMED",
            Content = "Successfully claimed rally!",
            Duration = 3,
            Image = "check-circle"
        })
        return true
    else
        print("❌ Sequence failed: " .. tostring(err))
        Rayfield:Notify({
            Title = "❌ CLAIM FAILED",
            Content = "Error: " .. tostring(err):sub(1, 50),
            Duration = 4,
            Image = "alert-triangle"
        })
        return false
    end
end

local function StartAutoRally(interval)
    if isRallyRunning then
        StopAutoRally()
    end
    
    if playerKey == "" then
        print("❌ Cannot start Auto Rally - No key entered!")
        Rayfield:Notify({
            Title = "❌ KEY REQUIRED",
            Content = "Please enter a key first",
            Duration = 3,
            Image = "alert-triangle"
        })
        RallyToggle:Set(false)
        return
    end
    
    isRallyRunning = true
    local intervalMinutes = interval or RallyInterval.CurrentValue
    print("▶️ Auto Rally started - Running every " .. intervalMinutes .. " minute(s)")
    
    Rayfield:Notify({
        Title = "🔄 AUTO RALLY",
        Content = "Started - Running every " .. intervalMinutes .. " minute(s)",
        Duration = 3,
        Image = "clock"
    })
    
    -- Run immediately once
    task.spawn(function()
        RunRallySequence()
    end)
    
    -- Then run on interval
    rallyLoop = task.spawn(function()
        while isRallyRunning do
            for i = 1, intervalMinutes * 60 do
                task.wait(1)
                if not isRallyRunning then break end
            end
            
            if isRallyRunning then
                RunRallySequence()
            end
        end
    end)
end

local function StopAutoRally()
    isRallyRunning = false
    if rallyLoop then
        rallyLoop = nil
    end
    print("⏹️ Auto Rally stopped")
    
    Rayfield:Notify({
        Title = "⏹️ AUTO RALLY",
        Content = "Auto Rally stopped",
        Duration = 2,
        Image = "square"
    })
end

-- Create Tabs
local MainTab = Window:CreateTab("Main Controls", "settings")
local RallyTab = Window:CreateTab("Auto Rally", "clock")
local VisualTab = Window:CreateTab("Visual", "eye")
local BattleTab = Window:CreateTab("Battle System", "swords")

-- ========== MAIN TAB ==========
MainTab:CreateSection("Music System")

MainTab:CreateButton({
   Name = "▶️ PLAY MUSIC",
   Callback = function()
        playMusic()
        Rayfield:Notify({
            Title = "MUSIC STARTED",
            Content = "Now playing track ID: "..musicId,
            Duration = 3,
            Image = "music"
        })
   end
})

MainTab:CreateButton({
   Name = "⏹ STOP MUSIC",
   Callback = function()
        if musicSound then 
            musicSound:Stop()
            Rayfield:Notify({
                Title = "MUSIC STOPPED",
                Content = "Audio playback disabled",
                Duration = 2,
                Image = "volume-x"
            })
        end
   end
})

MainTab:CreateSection("Hunting System")

local TeleportToggle = MainTab:CreateToggle({
   Name = "⚡ AUTO-TELEPORT",
   CurrentValue = false,
   Flag = "TeleportToggle",
   Callback = function(Value)
        if Value then 
            playMusic()
            Rayfield:Notify({
                Title = "HUNTING MODE",
                Content = "Teleport system activated",
                Duration = 3,
                Image = "target"
            })
        else
            Rayfield:Notify({
                Title = "HUNTING MODE",
                Content = "Teleport system deactivated",
                Duration = 3,
                Image = "circle-slash"
            })
        end
   end
})

MainTab:CreateSlider({
   Name = "📏 Y-AXIS LIMIT",
   Range = {1, 5000},
   Increment = 1,
   Suffix = "studs",
   CurrentValue = 1000,
   Flag = "YLimit",
   Callback = function(Value)
        yLimit = Value
   end
})

MainTab:CreateSlider({
   Name = "⏱ TELEPORT RATE",
   Range = {0.1, 1},
   Increment = 0.01,
   Suffix = "seconds",
   CurrentValue = 0.39,
   Flag = "TeleportRate",
   Callback = function(Value)
        teleportRate = Value
        Rayfield:Notify({
            Title = "SYSTEM UPDATE",
            Content = "Teleport delay: "..Value.." seconds",
            Duration = 2,
            Image = "clock"
        })
   end
})

-- ========== RALLY TAB ==========
RallyTab:CreateSection("Auto Rally System")

local KeyInput = RallyTab:CreateInput({
    Name = "Enter Your Key (REQUIRED)",
    PlaceholderText = "You MUST enter a key for Auto Rally to work",
    RemoveTextAfterFocusLost = false,
    Flag = "PlayerKey",
    Callback = function(Text)
        playerKey = Text
        print("🔑 Key set to: " .. Text)
        Rayfield:Notify({
            Title = "KEY SET",
            Content = "Rally key has been saved",
            Duration = 2,
            Image = "key"
        })
    end
})

RallyTab:CreateLabel("⚠️ Key is REQUIRED - Auto Rally won't start without it")

local RallyInterval = RallyTab:CreateSlider({
    Name = "Rally Interval (minutes)",
    Range = {1, 9},
    Increment = 1,
    CurrentValue = 9,
    Flag = "RallyInterval",
    Callback = function(Value)
        if isRallyRunning then
            print("🔄 Interval changed to " .. Value .. " minute(s) - restarting...")
            StartAutoRally(Value)
        end
    end
})

local RallyToggle = RallyTab:CreateToggle({
    Name = "Auto Rally",
    CurrentValue = false,
    Flag = "RallyToggle",
    Callback = function(Value)
        if Value then
            StartAutoRally(RallyInterval.CurrentValue)
        else
            StopAutoRally()
        end
    end
})

RallyTab:CreateButton({
    Name = "Run Rally Sequence Now",
    Callback = function()
        if playerKey == "" then
            Rayfield:Notify({
                Title = "❌ KEY REQUIRED",
                Content = "Please enter a key first",
                Duration = 3,
                Image = "alert-triangle"
            })
            return
        end
        RunRallySequence()
    end
})

RallyTab:CreateButton({
    Name = "Test Current Key",
    Callback = function()
        if playerKey ~= "" then
            print("🔑 Current key: " .. playerKey)
            Rayfield:Notify({
                Title = "KEY INFO",
                Content = "Key length: " .. #playerKey .. " characters",
                Duration = 3,
                Image = "key"
            })
        else
            print("❌ No key entered - Auto Rally will not work")
            Rayfield:Notify({
                Title = "❌ NO KEY",
                Content = "Please enter a key - REQUIRED",
                Duration = 3,
                Image = "alert-triangle"
            })
        end
    end
})

local StatusLabel = RallyTab:CreateLabel("Status: Idle")

task.spawn(function()
    while true do
        if isRallyRunning then
            StatusLabel:Set("Status: Auto Rally Active (Interval: " .. RallyInterval.CurrentValue .. " min)")
        elseif playerKey == "" then
            StatusLabel:Set("Status: Waiting for Key (Required)")
        else
            StatusLabel:Set("Status: Idle")
        end
        task.wait(1)
    end
end)

-- ========== VISUAL TAB ==========
VisualTab:CreateButton({
   Name = "🟩 SPAWN BASEPLATE",
   Callback = function()
        if baseplate then baseplate:Destroy() end
        baseplate = Instance.new("Part", workspace)
        baseplate.Size = Vector3.new(2000, 5, 2000)
        baseplate.Position = character.HumanoidRootPart.Position + Vector3.new(0, 50, 0)
        baseplate.Anchored = true
        baseplate.Color = Color3.fromRGB(0, 200, 100)
        baseplate.Material = Enum.Material.Neon
        baseplate.Name = "OwnerBaseplate"
        baseplate.Transparency = 0.3

        coroutine.wrap(function()
            while baseplate and baseplate.Parent do
                baseplate.Position = character.HumanoidRootPart.Position + Vector3.new(0, 50, 0)
                task.wait(0.1)
            end
        end)()

        Rayfield:Notify({
            Title = "VISUAL SYSTEM",
            Content = "Baseplate spawned 50 studs above",
            Duration = 3,
            Image = "box"
        })
   end
})

VisualTab:CreateSection("Anti-Lag System")

VisualTab:CreateButton({
    Name = "🚀 ENABLE ANTI-LAG",
