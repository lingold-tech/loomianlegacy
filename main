-- Combined Script: Auto Rally + Owner's Edition Features + Auto Battle
local Rayfield

-- Try multiple ways to load Rayfield
local success, result = pcall(function()
    Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
end)

if not success or not Rayfield then
    -- Fallback to a different URL
    success, result = pcall(function()
        Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua'))()
    end)
end

if not success or not Rayfield then
    warn("Failed to load Rayfield UI Library")
    return
end

local Window = Rayfield:CreateWindow({
   Name = "Koontang is fat",
   LoadingTitle = "Premium Egg Hunter + Auto Rally",
   LoadingSubtitle = "Owner's Edition",
   Theme = "Bloom",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "KoontangIsFatConfig",
      FileName = "Settings"
   },
   Discord = {
      Enabled = false,
      Invite = "noinvitelink",
      RememberJoins = true
   },
   KeySystem = false
})

-- Core Variables
local player = game:GetService("Players").LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local PlayerGui = player:WaitForChild("PlayerGui")
local musicId = 5410086218
local musicSound
local yLimit = 1000
local teleportRate = 0.39
local baseplate = nil
local AutoBattleEnabled = true
local Main = nil
local WildBattleToggle = false
local FastForwardToggle = false

-- Auto Battle Variables
local Moves = {
    [1] = false,
    [2] = false,
    [3] = true,
    [4] = false
}
local maxEnergyMove = 20
local clickOffsets = Vector2.new(0,0)

local KeepPokemon = {
    ["duskit"] = true, ["ikazune"] = true, ["protogon"] = true, ["dakuda"] = true,
    ["cosmeleon"] = true, ["cephalops"] = true, ["elephage"] = true, ["glacadia"] = true,
    ["arceros"] = true, ["metronette"] = true, ["nevermare"] = true, ["gargolem"] = true,
    ["odoyaga"] = true, ["wabalisc"] = true, ["akhalos"] = true, ["celesting"] = true,
    ["mimask"] = true, ["grimyuline"] = true, ["phagenaut"] = true, ["novadeaus"] = true,
    ["cosmiore"] = true, ["nymaurae"] = true, ["nymesis"] = true,
}

-- Rally Variables
local isRallyRunning = false
local rallyLoop = nil
local REQEvent = game:GetService("ReplicatedStorage"):FindFirstChild("Remote") and game:GetService("ReplicatedStorage").Remote:FindFirstChild("REQ")
local playerKey = ""

-- Safety check for REQ event
if not REQEvent then
    warn("REQ Remote not found! Auto Rally may not work.")
end

-- Clean up existing sounds
for _, sound in pairs(workspace:GetDescendants()) do
    if sound:IsA("Sound") then sound:Destroy() end
end

-- Music System
local function playMusic()
    if musicSound then musicSound:Stop() end
    musicSound = Instance.new("Sound")
    musicSound.Parent = workspace
    musicSound.SoundId = "rbxassetid://"..musicId
    musicSound.Looped = true
    musicSound.Volume = 0.5
    musicSound:Play()
end

-- Anti-lag system
local function optimizeGame()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        game.Lighting.GlobalShadows = false
        for _,v in pairs(game.Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                v.Enabled = false
            elseif v:IsA("BasePart") and v.Material == Enum.Material.Grass then
                v.Material = Enum.Material.SmoothPlastic
            end
        end
    end)
end

local function deactivateLag()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        game.Lighting.GlobalShadows = true
        for _,v in pairs(game.Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                v.Enabled = true
            end
        end
    end)
end

-- Battle Detection
local function isInBattle()
    return PlayerGui:FindFirstChild("BattleGui", true) ~= nil
end

-- Egg Detection System
local function getEggs()
    local eggs = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "Egg" and obj.Position.Y <= yLimit then
            table.insert(eggs, obj)
        end
    end
    return eggs
end

-- ========== AUTO BATTLE FUNCTIONS ==========
-- Find Main for battle system
for _,v in pairs(getgc(true)) do
    if typeof(v) == "table" and rawget(v, "DataManager") then
        Main = v
        break
    end
end

local function isRarePokemon()
    if not Main or not Main.Battle or not Main.Battle.currentBattle then return false end
    local success, result = pcall(function()
        local foe = Main.Battle.currentBattle.p1.foe.active[1]
        return foe and KeepPokemon[string.lower(foe.species)]
    end)
    return success and result
end

local function getCenter(button)
    local pos = button.AbsolutePosition
    local size = button.AbsoluteSize
    return Vector2.new(pos.X + size.X/2, pos.Y + size.Y/2)
end

local function clickButton(btn)
    if btn and btn.Parent and btn.Parent.Visible then
        local p = getCenter(btn)
        mousemoveabs(p.X, p.Y)
        mouse1click()
        task.wait(0.25)
    end
end

-- ========== RALLY SEQUENCE (KEY REQUIRED) ==========
local function RunRallySequence()
    if not REQEvent then
        print("❌ REQ Remote not found!")
        return false
    end
    
    -- KEY IS REQUIRED - don't run if no key
    if playerKey == "" then
        print("⚠️ No key entered - skipping claim")
        return false
    end
    
    print("🚀 Running rally sequence at: " .. os.date("%H:%M:%S"))
    print("  🔑 Using key: " .. playerKey)
    
    -- Show prompt before claiming
    Rayfield:Notify({
        Title = "🎯 RALLY READY",
        Content = "Preparing to claim rally...",
        Duration = 2,
        Image = "alert-circle"
    })
    
    local success, err = pcall(function()
        -- Step 1: ranchStatus
        print("  Step 1: ranchStatus")
        REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "ranchStatus"
        )
        
        -- Brief pause between steps
        task.wait(0.5)
        
        -- Step 2: getRallied
        print("  Step 2: getRallied")
        REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "getRallied"
        )
        
        -- Brief pause between steps
        task.wait(0.5)
        
        -- Step 3: handleRallied (the actual claim)
        print("  Step 3: handleRallied")
        REQEvent:InvokeServer(
            playerKey,
            "PDS",
            "handleRallied",
            {
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2,
                2
            }
        )
    end)
    
    if success then
        print("✅ Rally sequence completed at: " .. os.date("%H:%M:%S"))
        -- Success notification
        Rayfield:Notify({
            Title = "✅ RALLY CLAIMED",
            Content = "Successfully claimed rally!",
            Duration = 3,
            Image = "check-circle"
        })
        return true
    else
        print("❌ Sequence failed: " .. tostring(err))
        -- Failure notification
        Rayfield:Notify({
            Title = "❌ CLAIM FAILED",
            Content = "Error: " .. tostring(err):sub(1, 50),
            Duration = 4,
            Image = "alert-triangle"
        })
        return false
    end
end

-- Fixed interval handling
local function StartAutoRally(interval)
    if isRallyRunning then
        StopAutoRally()
    end
    
    -- Check if key exists before starting
    if playerKey == "" then
        print("❌ Cannot start Auto Rally - No key entered!")
        Rayfield:Notify({
            Title = "❌ KEY REQUIRED",
            Content = "Please enter a key first",
            Duration = 3,
            Image = "alert-triangle"
        })
        RallyToggle:Set(false)
        return
    end
    
    isRallyRunning = true
    local intervalMinutes = interval or RallyInterval.CurrentValue
    print("▶️ Auto Rally started - Running every " .. intervalMinutes .. " minute(s)")
    
    -- Notify that auto rally has started
    Rayfield:Notify({
        Title = "🔄 AUTO RALLY",
        Content = "Started - Running every " .. intervalMinutes .. " minute(s)",
        Duration = 3,
        Image = "clock"
    })
    
    -- Run immediately once
    task.spawn(function()
        RunRallySequence()
    end)
    
    -- Then run on interval
    rallyLoop = task.spawn(function()
        while isRallyRunning do
            -- Wait for the interval
            for i = 1, intervalMinutes * 60 do
                task.wait(1)
                if not isRallyRunning then break end
            end
            
            -- Run the sequence if still running
            if isRallyRunning then
                RunRallySequence()
            end
        end
    end)
end

local function StopAutoRally()
    isRallyRunning = false
    if rallyLoop then
        rallyLoop = nil
    end
    print("⏹️ Auto Rally stopped")
    
    -- Notify that auto rally has stopped
    Rayfield:Notify({
        Title = "⏹️ AUTO RALLY",
        Content = "Auto Rally stopped",
        Duration = 2,
        Image = "square"
    })
end

