})

-- ========== MAIN HUNTING LOOP ==========
task.spawn(function()
    while task.wait() do
        pcall(function()
            if TeleportToggle and TeleportToggle.CurrentValue and not isInBattle() then
                local eggs = getEggs()
                for _, egg in ipairs(eggs) do
                    if not TeleportToggle.CurrentValue or isInBattle() then 
                        if isInBattle() then
                            print("⚠️ [CONSOLE] Battle detected, teleport paused")
                            Rayfield:Notify({
                                Title = "COMBAT DETECTED",
                                Content = "Teleportation paused",
                                Duration = 3,
                                Image = "swords"
                            })
                        end
                        break 
                    end
                    if egg and egg.Parent then
                        humanoid.RootPart.CFrame = CFrame.new(egg.Position)
                        task.wait(teleportRate)
                    end
                end
            end
        end)
    end
end)

-- ========== REWORKED AUTO-BATTLE LOOP (using REQ remote with tryRun) ==========
task.spawn(function()
    while task.wait() do
        pcall(function()
            if AutoBattleEnabled then
                local BattleGui = PlayerGui:FindFirstChild("BattleGui", true)
                if BattleGui and currentWildID and playerKey ~= "" then
                    -- Use the REQ remote to execute a move
                    REQEvent:InvokeServer(playerKey, "BattleFunction", currentWildID, "tryRun")
                    print("⚔️ [CONSOLE] Auto-battle: used tryRun against " .. currentWildID)
                    task.wait(1) -- delay to avoid spamming
                elseif BattleGui and not currentWildID then
                    print("⚠️ [CONSOLE] In battle but no wild ID captured yet")
                elseif BattleGui and playerKey == "" then
                    print("⚠️ [CONSOLE] In battle but no player key set")
                end
            end
        end)
    end
end)

-- ========== WILD BATTLE SPAWNER LOOP ==========
task.spawn(function()
    while task.wait(1) do
        pcall(function()
            if WildBattleToggle and Main and Main.DataManager and Main.DataManager.currentChunk and Main.DataManager.currentChunk.regionData and Main.DataManager.currentChunk.regionData.Grass then
                if Main.Battle and Main.Battle.currentBattle then
                    Main.Battle.currentBattle.BattleEnded:Fire()
                    Main.Battle.currentBattle = nil
                    task.wait(0.5)
                end
                if Main.Battle and Main.Battle.doWildBattle then
                    Main.Battle.doWildBattle(Main.Battle, Main.DataManager.currentChunk.regionData.Grass, {})
                    print("🌿 [CONSOLE] Spawned wild battle")
                end
            end
        end)
    end
end)

-- ========== BATTLE FAST-FORWARD LOOP ==========
task.spawn(function()
    while task.wait() do
        pcall(function()
            if FastForwardToggle and Main and Main.Battle and Main.Battle.currentBattle then
                Main.Battle.currentBattle.fastForward = true
            end
        end)
    end
end)

-- Initialize
Rayfield:LoadConfiguration()

-- Load saved key
task.wait(1)
if KeyInput and KeyInput.CurrentValue and KeyInput.CurrentValue ~= "" then
    playerKey = KeyInput.CurrentValue
    keyCaptured = true
    print("💾 [CONSOLE] Loaded saved key: " .. playerKey)
end

-- Auto-start key extractor on load
task.wait(0.5)
StartKeyExtractor(KeyInput)

-- Welcome Notification
task.wait(0.5)
Rayfield:Notify({
   Title = "OWNER SYSTEM ONLINE",
   Content = "Premium controls activated\nAuto Rally + Egg Hunter\n🔍 Key extractor listening...",
   Duration = 6,
   Image = "shield-check"
})
print("✅ Script loaded - Key extractor active. Waiting for remote events...")
